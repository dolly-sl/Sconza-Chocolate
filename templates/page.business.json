    "plain_text_MHxaTc": {
      "type": "richText",
      "name": "Rich Text",
      "settings": {
        "heading": "A Partner Built on 87 Years of Expertise",
        "content": "<h3>Four generations of confectionery expertise, scaled for today’s brands and retailers.<\/h3><p><br\/>Sconza is a leading chocolate and confectionery partner, supporting national brands, retailers, and distributors across <strong>contract manufacturing<\/strong>, <strong>private label<\/strong>, and <strong>wholesale<\/strong> programs.<\/p><p>Our vertically integrated capabilities span product development, high-volume production, and distribution—delivering consistency, quality, and scale at every stage.<\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
    "rich_text_JPQgMA": {
      "type": "richText",
      "disabled": true,
      "name": "Rich Text",
      "settings": {
        "heading": "The Nation's Leader in Contract Manufacturing",
        "content": "<h3>Scale, quality, and speed — backed by four generations of candy-making.<\/h3><p>Sconza Candy Company is a trusted contract manufacturer for retailers and brands nationwide. From chocolate and sugar panning to finished confections, we help you bring great-tasting products to market with reliable capacity, consistent quality, and responsive service.<\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
