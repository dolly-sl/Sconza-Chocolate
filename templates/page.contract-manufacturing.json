    "plain_text_MHxaTc": {
      "type": "richText",
      "name": "Rich Text",
      "settings": {
        "heading": "Manufacturing Since 1939",
        "content": "<h3>Four generations of hands-on candy making, refined for modern scale.<\/h3><p><br\/>Sconza is a leading <strong>chocolate and confectionery contract manufacturer<\/strong>, producing high-quality panned confections and specialty products for national brands, retailers, and private label programs. Our vertically integrated manufacturing capabilities support brands at scale--from product development through high-volume production and national distribution.<br\/><\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
    "rich_text_JPQgMA": {
      "type": "richText",
      "disabled": true,
      "name": "Rich Text",
      "settings": {
        "heading": "The Nation's Leader in Contract Manufacturing",
        "content": "<h3>Scale, quality, and speed — backed by four generations of candy-making.<\/h3><p>Sconza Candy Company is a trusted contract manufacturer for retailers and brands nationwide. From chocolate and sugar panning to finished confections, we help you bring great-tasting products to market with reliable capacity, consistent quality, and responsive service.<\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
