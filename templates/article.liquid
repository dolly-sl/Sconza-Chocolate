<section class="article__single tw-bg-backgroundDark">
  {% comment %} ── ARTICLE HERO ── {% endcomment %}
  {%- assign hero_image = article.image -%}
  <section
    class="article__hero tw-relative tw-z-0 !tw-bg-no-repeat !tw-bg-cover !tw-bg-center"
    style="background-image:url({{ hero_image | image_url: width: hero_image.width }});"
  >
    <div class="wrapper">
      <div
        class="tw-h-[550px] md:tw-h-[500px] lg:tw-h-[650px] tw-flex tw-items-center lg:tw-text-left tw-text-center lg:tw-items-start tw-justify-center tw-flex-col"
      ></div>
    </div>
  </section>

  {% comment %} ── ARTICLE CONTAINER ── {% endcomment %}
  <div class="tw-container tw-mt-9">
    <div class="inner blog-inner">
      {% comment %}
        ════════════════════════════════════════
            NEW BLOG HEADER  (matches design images)
        ════════════════════════════════════════
      {% endcomment %}
      <div class="blog-header">
        {% comment %} ROW 1 – Breadcrumb + Share {% endcomment %}
        <div class="blog-header__top">
          {% comment %} Breadcrumb {% endcomment %}
          {% comment %}
            <nav class="blog-breadcrumb" aria-label="Breadcrumb">
              <a href="/" class="blog-breadcrumb__link">Home</a>
              <span class="blog-breadcrumb__sep" aria-hidden="true">/</span>
              <a href="{{ blog.url }}" class="blog-breadcrumb__link">{{ blog.title }}</a>
              <span class="blog-breadcrumb__sep" aria-hidden="true">/</span>
              <span class="blog-breadcrumb__current">{{ article.title | truncate: 40 }}</span>
            </nav>
          {% endcomment %}
        </div>

        {% comment %} ROW 2 – Date + Category Tags {% endcomment %}
        <div class="blog-header__meta">
          <span class="article__date eyebrow"> {{ article.published_at | date: '%B %e, %Y' }} / </span>

          {% comment %} Article Tags / Categories {% endcomment %}
          {% if article.tags.size > 0 %}
            <div class="blog-header__tags">
              {% for tag in article.tags %}
                <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="blog-header__tag">
                  {{ tag }}
                </a>
                {% unless forloop.last %},{% endunless %}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {% comment %} ROW 3 – Article Title {% endcomment %}
        <h1 class="tw-text-mainBlack2 tw-text-[35px] tw-font-bold tw-font-osc tw-uppercase tw-text-left article__title">
          {{ article.title }}
        </h1>

        {% comment %} ROW 4 – Author {% endcomment %}
        {% comment %}
          {% if article.author %}
            <p class="blog-header__author">
              By <strong>{{ article.author }}</strong>
            </p>
          {% endif %}
        {% endcomment %}
        {% comment %} Social Share Icons {% endcomment %}
        <div class="blog-share">
          <span class="blog-share__label">Share:</span>

          {% comment %} Facebook {% endcomment %}
          <a
            href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}"
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share__btn blog-share__btn--facebook"
            aria-label="Share on Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="8" height="15" viewBox="0 0 8 15" fill="none">
              <path d="M1.81923 14.4263H4.85636V8.34446H7.5928L7.89348 5.32254H4.85636V3.79639C4.85636 3.59502 4.93635 3.40189 5.07874 3.2595C5.22114 3.11711 5.41426 3.03711 5.61563 3.03711H7.89348V0H5.61563C4.60877 0 3.64314 0.399976 2.93117 1.11194C2.21921 1.8239 1.81923 2.78952 1.81923 3.79639V5.32254H0.300675L0 8.34446H1.81923V14.4263Z" fill="#1E1C1C"/>
            </svg>
          </a>

          {% comment %} Pinterest {% endcomment %}
          <a
            href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&description={{ article.title | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share__btn blog-share__btn--pinterest"
            aria-label="Share on Pinterest"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="17" viewBox="0 0 14 17" fill="none">
              <path d="M5.36182 10.6072C4.92067 12.815 4.38362 14.9321 2.78989 16.0376C2.29905 12.7008 3.51265 10.1941 4.07586 7.53356C3.11509 5.98663 4.19181 2.87251 6.21797 3.6395C8.71143 4.58386 4.05842 9.3915 7.18223 9.99245C10.4438 10.6193 11.776 4.57981 9.75328 2.61496C6.83087 -0.22054 1.24674 2.55098 1.93375 6.61107C2.10114 7.60402 3.17263 7.90531 2.36182 9.27568C0.491722 8.87801 -0.0662556 7.46715 0.00610712 5.58572C0.12119 2.50805 2.898 0.352068 5.68266 0.0540202C9.2049 -0.323399 12.51 1.29076 12.966 4.45994C13.4804 8.03652 11.3767 11.9111 7.61117 11.6317C6.59025 11.5564 6.1613 11.0729 5.36182 10.6072Z" fill="#1E1C1C"/>
            </svg>
          </a>

          {% comment %} Twitter / X {% endcomment %}
          <a
            href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="blog-share__btn blog-share__btn--twitter"
            aria-label="Share on X (Twitter)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="13" viewBox="0 0 16 13" fill="none">
              <path d="M15.8841 1.51856C15.2995 1.7843 14.6693 1.95894 14.0163 2.04246C14.6845 1.64004 15.2008 1.00225 15.4438 0.235376C14.8136 0.615015 14.115 0.880763 13.3785 1.03262C12.7787 0.379639 11.9359 0 10.9792 0C9.19488 0 7.73706 1.45781 7.73706 3.2573C7.73706 3.51546 7.76744 3.76602 7.82059 4.0014C5.11755 3.86473 2.71063 2.56636 1.10855 0.59983C0.827615 1.07817 0.668167 1.64004 0.668167 2.23228C0.668167 3.3636 1.23763 4.36585 2.11839 4.93531C1.5793 4.93531 1.07818 4.78345 0.637795 4.55567V4.57845C0.637795 6.15774 1.76153 7.47889 3.24972 7.77501C2.77192 7.90576 2.27032 7.92395 1.78431 7.82816C1.99053 8.47543 2.39442 9.04179 2.93919 9.44764C3.48395 9.85349 4.14221 10.0784 4.82143 10.0908C3.67008 11.0023 2.24291 11.4949 0.774466 11.4879C0.51631 11.4879 0.258155 11.4727 0 11.4423C1.44263 12.3686 3.15861 12.9077 4.99606 12.9077C10.9792 12.9077 14.2669 7.94205 14.2669 3.63694C14.2669 3.49268 14.2669 3.35601 14.2593 3.21175C14.8971 2.75618 15.4438 2.17913 15.8841 1.51856Z" fill="#1E1C1C"/>
            </svg>
          </a>

          {% comment %} Copy Link {% endcomment %}
          <button
            class="blog-share__btn blog-share__btn--copy"
            aria-label="Copy link"
            onclick="
              navigator.clipboard.writeText('{{ shop.url }}{{ article.url }}');
              this.classList.add('copied');
              this.setAttribute('aria-label','Copied!');
              setTimeout(()=>{
                this.classList.remove('copied');
                this.setAttribute('aria-label','Copy link');
              }, 2000);
            "
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none">
              <path d="M15.1856 3.73846H13.4334V0H2.92031V3.73846H1.16812C0.858317 3.73846 0.561201 3.86975 0.342135 4.10345C0.12307 4.33715 0 4.65412 0 4.98462V11.2154C0 11.5459 0.12307 11.8629 0.342135 12.0965C0.561201 12.3302 0.858317 12.4615 1.16812 12.4615H2.92031V16.2H13.4334V12.4615H15.1856C15.4954 12.4615 15.7925 12.3302 16.0116 12.0965C16.2307 11.8629 16.3537 11.5459 16.3537 11.2154V4.98462C16.3537 4.65412 16.2307 4.33715 16.0116 4.10345C15.7925 3.86975 15.4954 3.73846 15.1856 3.73846ZM4.08843 1.24615H12.2653V3.73846H4.08843V1.24615ZM12.2653 14.9538H4.08843V8.72308H12.2653V14.9538ZM15.1856 11.2154H13.4334V7.47692H2.92031V11.2154H1.16812V4.98462H15.1856V11.2154Z" fill="#1E1C1C"/>
            </svg>
            <span class="blog-share__copy-tip">Copied!</span>
          </button>
        </div>
      </div>
      {% comment %} /blog-header {% endcomment %}

      {% comment %}
        ════════════════════════════════════════
            ARTICLE CONTENT  (shortcode logic kept as-is)
        ════════════════════════════════════════
      {% endcomment %}
      <div class="article__content">
        {%- comment -%} 1. Capture custom_section design {%- endcomment -%}
        {%- capture custom_design -%}
          {% render 'article-shortcode' %}
        {%- endcapture -%}

        {%- comment -%} 2. Replace [custom_section] {%- endcomment -%}
        {% assign parsed_content = article.content | replace: '[custom_section]', custom_design %}

        {%- comment -%} 3. Replace each product shortcode {%- endcomment -%}
        {% for tag in article.tags -%}
        {%- endfor -%}
        {% comment %}dummy loop to allow assign{% endcomment %}

        {% assign product_handles = parsed_content | split: '[product handle="' %}

        {% assign final_content = product_handles[0] %}

        {% for chunk in product_handles %}
          {% unless forloop.first %}
            {% assign handle_and_rest = chunk | split: '"]' %}

            {% assign sc_handle = handle_and_rest[0] | strip %}

            {% assign after_shortcode = handle_and_rest[1] %}

            {%- capture product_html -%}
        {% render 'shortcode-product', sc_handle: sc_handle %}
      {%- endcapture -%}

            {% assign final_content = final_content | append: product_html | append: after_shortcode %}
          {% endunless %}
        {% endfor %}

        {{ final_content }}
      </div>

      {% comment %}
        ════════════════════════════════════════
            ARTICLE FOOTER  –  Tags + Prev/Next
        ════════════════════════════════════════
      {% endcomment %}
      <div class="article__footer">
        {% comment %} Prev / Next Navigation {% endcomment %}
        <div class="article__pagination">
          {% comment %} Previous Article {% endcomment %}
          {% if blog.previous_article %}
            <a href="{{ blog.previous_article.url }}" class="article__pagination-btn article__pagination-btn--prev">
              {% comment %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15 18 9 12 15 6"/>
                </svg>
              {% endcomment %}
              <span class="article__pagination-direction">Prev</span>
              {% comment %} <span class="article__pagination-title">{{ blog.previous_article.title | truncate: 50 }}</span> {% endcomment %}
            </a>
          {% else %}
            <span class="article__pagination-btn article__pagination-btn--prev article__pagination-btn--disabled">
              {% comment %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15 18 9 12 15 6"/>
                </svg>
              {% endcomment %}
              <span class="article__pagination-direction">Previous</span>
              {% comment %} <span class="article__pagination-title">No previous post</span> {% endcomment %}
            </span>
          {% endif %}

          {% comment %} Tags Row {% endcomment %}
          {% if article.tags.size > 0 %}
            <div class="article__footer-tags">
              <span class="article__footer-tags__label">Tags:</span>
              {% for tag in article.tags %}
                <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="article__footer-tag">
                  {{ tag }}
                </a>
                {% unless forloop.last %},{% endunless %}
              {% endfor %}
            </div>
          {% endif %}

          {% comment %} Next Article {% endcomment %}
          {% if blog.next_article %}
            <a href="{{ blog.next_article.url }}" class="article__pagination-btn article__pagination-btn--next">
              <span class="article__pagination-direction">Next</span>
              {% comment %} <span class="article__pagination-title">{{ blog.next_article.title | truncate: 50 }}</span> {% endcomment %}
              {% comment %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              {% endcomment %}
            </a>
          {% else %}
            <span class="article__pagination-btn article__pagination-btn--next article__pagination-btn--disabled">
              <span class="article__pagination-direction">Next</span>
              {% comment %} <span class="article__pagination-title">No next post</span> {% endcomment %}
              {% comment %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              {% endcomment %}
            </span>
          {% endif %}
        </div>
        {% comment %} /article__pagination {% endcomment %}
      </div>
      {% comment %} /article__footer {% endcomment %}
    </div>
    {% comment %} /inner {% endcomment %}
  </div>
  {% comment %} /tw-container {% endcomment %}
</section>

{% comment %} ── KEEP EXPLORING (Related Articles) ── {% endcomment %}
<section class="article__related tw-bg-backgroundDark">
  <div class="tw-container">
    <h2 class="tw-text-center tw-text-mainBlack2 tw-font-bold tw-font-osc tw-uppercase related-blog-title">
      KEEP EXPLORING
    </h2>
    <div class="related__wrap d-flex">
      {% if article.metafields.sleepless.related_article_1 != blank
        or article.metafields.sleepless.related_article_2 != blank
        or article.metafields.sleepless.related_article_3 != blank
      %}
        {% if article.metafields.sleepless.related_article_1 != blank %}
          {% assign article_one = articles[article.metafields.sleepless.related_article_1] %}
          {% render 'default-article', data: article_one %}
        {% endif %}

        {% if article.metafields.sleepless.related_article_2 != blank %}
          {% assign article_two = articles[article.metafields.sleepless.related_article_2] %}
          {% render 'default-article', data: article_two %}
        {% endif %}

        {% if article.metafields.sleepless.related_article_3 != blank %}
          {% assign article_three = articles[article.metafields.sleepless.related_article_3] %}
          {% render 'default-article', data: article_three %}
        {% endif %}

      {% else %}
        {% for article in blog.articles limit: 3 %}
          {% render 'default-article', data: article %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% comment %}
  ══════════════════════════════════════════════════════
      ALL STYLES  –  New additions only. Existing styles kept below.
  ══════════════════════════════════════════════════════
{% endcomment %}
<style>
  /* ─── Scope ─────────────────────────────────────────────── */
  .article__single .article__content,
  .blog-header {
    max-width: 950px;
    margin: auto;
  }
  .blog-header h1 {
    font-size: 55px;
    line-height: normal;
    font-weight: 700;
  }
  /* ─── Existing styles (unchanged) ──────────────────────── */
  .blog-header {
    border-bottom: 1px solid #a79e8999;
    padding-bottom: 30px;
    margin-bottom: 10px;
  }
  .article__content p,
  .article__content li {
    line-height: 28px;
    color: #1a1b1b;
    padding-top: 20px;
    font-size: 16px;
    margin: 0;
    list-style-type: disc;
  }
  .article__content ul li {
    padding-left: 5px;
    padding-top: 5px;
  }
  .article__content ul,
  .article__content ol {
    padding-left: 20px;
  }
  .article-custom-section ol li {
    list-style-type: auto;
    padding-top: 5px;
  }
  .article__content h1 {
    font-size: 55px;
    color: #1e1c1c;
    font-weight: 700;
    letter-spacing: 0.413px;
    text-transform: uppercase;
    padding-top: 50px;
  }
  .article__content h2 {
    font-size: 35px;
    color: #1e1c1c;
    font-weight: 700;
    letter-spacing: 0.413px;
    text-transform: uppercase;
    padding-top: 50px;
  }

  .article__content h3 {
    font-size: 25px;
    color: #1e1c1c;
    font-weight: 700;
    letter-spacing: 0.413px;
    text-transform: uppercase;
    padding-top: 50px;
  }

  .article__content h4 {
    font-size: 16px;
    color: #1e1c1c;
    font-weight: 700;
    letter-spacing: 0.413px;
    text-transform: uppercase;
    padding-top: 50px;
  }

  .article__content h5 {
    font-size: 16px;
    font-style: italic;
    color: #1e1c1c;
    font-weight: 700;
    letter-spacing: 0.413px;
    text-transform: uppercase;
    padding-top: 50px;
  }

  .article__content h6 {
    font-size: 16px;
    font-weight: 400;
    color: #1e1c1c;
    font-weight: 700;
    letter-spacing: 0.413px;
    text-transform: uppercase;
    padding-top: 50px;
  }

  /* ─── NEW: Blog Header Top Row ──────────────────────────── */
  .blog-header__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  /* Breadcrumb */
  .blog-breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 12px;
    color: #6b6b6b;
  }
  .blog-breadcrumb__link {
    color: #6b6b6b;
    text-decoration: none;
    transition: color 0.2s;
  }
  .blog-breadcrumb__link:hover {
    color: #1a1b1b;
    text-decoration: underline;
  }
  .blog-breadcrumb__sep {
    color: #a79e89;
    margin: 0 2px;
  }
  .blog-breadcrumb__current {
    color: #1a1b1b;
    font-weight: 500;
  }

  /* Share bar */
  .blog-share {
    display: flex;
    align-items: center;
    margint-top: 10px;
  }
  .blog-share__label {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.5px;
    color: #1e1c1c;
    margin-right: 10px;
  }
  .blog-share svg:hover path {
    fill: #df9832;
  }
  .blog-share__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: #1e1c1c;
    cursor: pointer;
    transition: 0.5s all ease-in-out;
    position: relative;
    margin-right: 8px;
  }
  /* Specific brand hover colours */
  .blog-share__btn--facebook:hover {
    color: #1877f2;
  }
  .blog-share__btn--twitter:hover {
    color: #000;
  }
  .blog-share__btn--pinterest:hover {
    color: #e60023;
  }

  /* Copy tooltip */
  .blog-share__copy-tip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) scale(0.85);
    background: #1a1b1b;
    color: #fff;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .blog-share__btn--copy.copied .blog-share__copy-tip {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }

  /* ─── NEW: Meta row (date + tag pills) ───────────────────── */
  .blog-header__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }
  .article__date {
    font-size: 14px;
    color: #1e1c1c;
    font-weight: 600;
    text-transform: normal;
    letter-spacing: 0;
    text-transform: normal;
    margin-right: 5px;
  }
  .blog-header__tags {
    display: flex;
    flex-wrap: wrap;
    color: #df9832;
  }
  .blog-header__tag {
    padding-left: 5px;
    font-size: 14px;
    font-weight: 600;
  }
  .blog-header__tag:hover {
    background: #1a1b1b;
    color: #fff;
    border-color: #1a1b1b;
  }

  /* ─── NEW: Author line ────────────────────────────────────── */
  .blog-header__author {
    font-size: 13px;
    color: #6b6b6b;
    margin-top: 8px;
    margin-bottom: 0;
  }
  .blog-header__author strong {
    color: #1a1b1b;
  }

  /* ─── NEW: Article Footer ────────────────────────────────── */
  .article__footer {
    max-width: 950px;
    margin: 0 auto !important;
    border-top: 1px solid rgba(167, 158, 137, 0.6);
    border-bottom: 1px solid rgba(167, 158, 137, 0.6);
    padding: 20px 30px !important;
    display: flex;
    justify-content: space-between;
    width: 100%;
  }
  .article__single .article__content {
    padding-bottom: 70px;
  }
  /* Footer Tags */
  .article__footer-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }
  .article__footer-tags__label {
    font-size: 14px;
    font-weight: 400;
    color: #1e1c1c;
    margin-right: 5px;
  }
  .article__footer-tag {
    display: inline-block;
    font-size: 14px;
    font-weight: 400;
    text-transform: none !important;
    padding-left: 5px !important;
    color: #1e1c1c;
    text-decoration: none;
  }

  /* Prev / Next Navigation */
  .article__pagination {
    width: 100% !important;
    display: flex;
    justify-content: space-between;
  }
  .article__pagination-btn {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: #1e1c1c;
    font-size: 14px;
    font-style: normal;
    font-weight: 700;
  }
  .article__pagination-btn--disabled {
    opacity: 0.5;
    cursor: default;
    pointer-events: none;
  }
  .article__pagination-btn--prev {
    align-items: flex-start;
    text-align: left;
  }
  .article__pagination-btn--next {
    align-items: flex-end;
    text-align: right;
  }
  /* direction label row */
  .article__pagination-btn--prev .article__pagination-direction,
  .article__pagination-btn--next .article__pagination-direction {
    display: flex;
    align-items: center;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    color: #1e1c1c;
    letter-spacing: 0;
  }
  .article__pagination-btn--next .article__pagination-direction {
    flex-direction: row-reverse;
  }
  .article__pagination-title {
    font-size: 14px;
    font-weight: 600;
    color: #1a1b1b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
