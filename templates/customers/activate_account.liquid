<section class="customer customer--login">
  <div class="container" id="login">
    <div class="customer__heading">
      <h1>Activate Account</h1>
    </div>
    <div class="customer__content">
      <div class="customer__form">
        {% form 'activate_customer_password' %}
          {{ form.errors | default_errors }}
      
          <div id="password" class="form__group">
            <label class="large" for="password">Password</label>
            <input type="password" value="" name="customer[password]" id="customer_password" class="large password" size="16" />
          </div>
          <div id="password_confirm" class="form__group">
            <label class="large" for="password_confirmation">Password Confirmation</label>
            <input type="password" value="" name="customer[password_confirmation]" id="customer_password_confirmation" class="large password" size="16" />
          </div>
          <div class="actions d-flex justify-center">
            <button type="submit" class="btn btn--solid">
              Activate Account
            </button>
            <span class="note">or</span>
            <input type="submit" class="cancel" name="decline" id="customer_decline" value="Decline Invitation" />
          </div>
        {% endform %}
      </div>
    </div>
  </div>
  
</section>