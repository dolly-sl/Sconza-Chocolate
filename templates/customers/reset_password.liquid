<section class="customer customer--login">
  <div class="container">
    <div class="customer__heading">
      <h1>Reset Password</h1>
    </div>
    <div class="customer__content">
      <div class="customer__form">
        {% form 'reset_customer_password' %}
          {{ form.errors | default_errors }}

          <div id="password" class="form__group"> 
            <label class="sr-only" for="password">Password</label>
            <input type="password" placeholder="Password" value="" name="customer[password]" id="customer_password" class="large password" size="16" />
          </div>
          <div id="password_confirm" class="form__group">
            <label class="sr-only" for="password_confirmation">Password Confirmation</label>
            <input type="password" placeholder="Confirm Password" value="" name="customer[password_confirmation]" id="customer_password_confirmation" class="large password" size="16" />
          </div>
          <div class="action_bottom">
            <button class="btn btn--green" type="submit">Reset Password</button>
          </div>
        {% endform %} 
      </div>
    </div>
  </div>
</section>
