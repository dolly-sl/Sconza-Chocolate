    "plain_text_MHxaTc": {
      "type": "richText",
      "name": "Rich Text",
      "settings": {
        "heading": "TRUSTED WHOLESALE CANDY MANUFACTURER<br>SINCE 1939",
        "content": "<p>Sconza is a trusted <strong>wholesale chocolate and candy supplier <\/strong>providing premium confectionery products to grocery retailers, club stores, and specialty food distributors. With four generations of confectionery expertise, we combine high-quality ingredients with scalable manufacturing and dependable nationwide distribution.<\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
    "rich_text_7jdrVG": {
      "type": "richText",
      "disabled": true,
      "name": "Rich Text",
      "settings": {
        "heading": "Trusted Since 1939 Four Generations of Candy Makers",
        "content": "<p><strong>Sconza Candy Company<\/strong> is a <strong>leading confectionery manufacturer and wholesale candy supplier<\/strong>, trusted by retailers, brands, and partners nationwide. Founded in <strong>1939<\/strong> and proudly family-owned for<strong> four generations<\/strong>, Sconza delivers premium confections through <strong>wholesale distribution, contract manufacturing, and private label candy programs<\/strong>.<\/p><p>With decades of category expertise and modern manufacturing capabilities, we help partners scale with confidence—from branded candy distribution to fully custom confectionery solutions.<\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
    "tagline_4CefMg": {
      "type": "tagline",
      "disabled": true,
      "settings": {
        "tagline": "Trusted Since 1939 | Four Generations of Candy Makers"
      }
    },
    "split_image_text_cRMdBV": {
      "type": "splitImageText",
      "blocks": {
        "block_qnbHRN": {
          "type": "block",
          "settings": {
            "image": "shopify:\/\/shop_images\/SconzaJordanAlmonds.png",
            "heading": "CANDY PROGRAMS BUILT FOR RETAIL",
            "subheading": "Wholesale",
            "content": "<p>Sconza is a leading <strong>wholesale chocolate and candy supplier for retail programs<\/strong>, offering:<\/p><ul><li>Bulk wholesale chocolate-covered nuts, fruits, caramels, cookie bites, gel fruit centers, and specialty confections<\/li><li>Includes seasonal and everyday candy assortments<\/li><li>Sconza branded packages - <em>Bites of Joy<\/em><\/li><li>Nationwide distribution<\/li><\/ul><p>From order placement through fulfillment, we make wholesale purchasing simple and scalable.<br\/><br\/><\/p>",
            "button_text": "",
            "button_link": "shopify:\/\/pages\/contact",
            "alignment": "left"
          }
        },
        "block_iafFNk": {
          "type": "block",
          "disabled": true,
          "settings": {
            "image": "shopify:\/\/shop_images\/Sconza_070.jpg",
            "heading": "Wholesale",
            "subheading": "Premium Quality Confections",
            "content": "<p>Sconza is a trusted <strong>wholesale candy manufacturer <\/strong>creating high-quality, innovative branded and bulk confections crafted with premium ingredients and quality manufacturing standards.   <\/p><p><strong>From product quality to fulfillment, we make it easy to grow with confidence:<\/strong><\/p><ul><li>Proven, best-selling quality confectionery products<\/li><li>Reliable supply chain and scalable production<\/li><li>Dedicated wholesale support and fulfillment<\/li><li>Easy ordering through our customer service department or self service online wholesale customer portal.<\/li><\/ul><p><\/p><p><\/p><p><\/p>",
            "button_text": "",
            "button_link": "shopify:\/\/pages\/contact",
            "alignment": "left"
          }
        },
        "block_hDRGYP": {
          "type": "block",
          "settings": {
            "image": "shopify:\/\/shop_images\/FactoryFloor-002.jpg",
            "heading": "PRODUCTION CAPABILITIES",
            "subheading": "Wholesale",
            "content": "<ul><li>190 coating pans supporting high-volume confectionery production<\/li><li>High-volume roasting and chocolate panning for wholesale candy programs<\/li><li>Mogul and deposited confection lines<\/li><li>On-site liquid chocolate system<\/li><li>Multi-shift, large-scale wholesale confectionery production<\/li><\/ul>",
            "button_text": "",
            "button_link": "shopify:\/\/pages\/contact",
            "alignment": "left"
          }
        },
        "block_3hCqYA": {
          "type": "block",
          "settings": {
            "image": "shopify:\/\/shop_images\/NEWTop4.png",
            "heading": "GROCERY, SPECIALTY, RETAILERS & Distributors",
            "subheading": "Wholesale Candy Supplier",
            "content": "<p>Sconza supplies premium wholesale chocolate and confectionery products to grocery retailers, specialty retailers, and distributors. Our wholesale programs are designed to support consistent inventory, strong shelf performance, and scalable distribution.<\/p>",
            "button_text": "",
            "button_link": "shopify:\/\/pages\/contact",
            "alignment": "left"
          }
        },
        "block_JrqUDm": {
          "type": "block",
          "disabled": true,
          "settings": {
            "image": "shopify:\/\/shop_images\/696-DCR03443_758c9bc3-175c-4fe3-9e4a-2c0e92a3ef77.jpg",
            "heading": "Capabilities",
            "subheading": "",
            "content": "<ul><li><strong>Panning - <\/strong>190 Coating Pans \/ 9 isolated rooms  <br\/>Sugar panning, sugar shelling & dextrose panning <\/li><li><strong>Hot Panning<\/strong> - Fire cookers <\/li><li><strong>Roasting <\/strong>- Continuous high-volume dry roaster <\/li><li><strong>Deposited Confections (Mogul Line<\/strong>) - Carmel, Pectin, marshmallow, mallow-cremes.   Gelatin & starch-based products <\/li><li><strong>Chocolate Buttons<\/strong> - Milk & Dark Chocolate, minis <\/li><li><strong>Liquid Chocolate System - 2<\/strong>4+ lbs of on-site chocolate storage <\/li><\/ul><p><\/p>",
            "button_text": "",
            "button_link": "shopify:\/\/pages\/contact",
            "alignment": "left"
          }
        }
      },
