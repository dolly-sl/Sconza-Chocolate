    "plain_text_MHxaTc": {
      "type": "richText",
      "name": "Rich Text",
      "settings": {
        "heading": "Proven Programs. Ready for Retail.",
        "content": "<h3>Private label programs designed to drive category growth and perform at retail.<\/h3><p><br\/>Sconza partners with retailers and national brands to deliver <strong>private label chocolate and confectionery manufacturing programs designed for retail success.<\/strong> Our ready-to-launch assortments combine premium ingredients, proven flavor profiles, and flexible packaging options to support grocery, club, and specialty retail distribution.<\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
    "rich_text_36wz6q": {
      "type": "richText",
      "disabled": true,
      "name": "Rich Text",
      "settings": {
        "heading": "Trusted Since 1939. Four Generations of Candy Makers.",
        "content": "<h3>Premium confections, ready for your brand.<\/h3><p>Sconza’s private label programs help retailers and partners launch distinctive candy assortments with speed and confidence. Built on four generations of confectionery expertise, our ready-to-scale offerings combine premium ingredients, proven best-sellers, and flexible packaging formats designed for today’s retail environment.<\/p>",
        "button_text": "",
        "button_url": ""
      }
    },
    "tagline_4CefMg": {
      "type": "tagline",
      "disabled": true,
      "settings": {
        "tagline": "Trusted Since 1939 | Four Generations of Candy Makers"
      }
    },
    "split_image_text_cRMdBV": {
      "type": "splitImageText",
      "blocks": {
        "block_rgN6kV": {
          "type": "block",
          "disabled": true,
          "settings": {
            "image": "shopify:\/\/shop_images\/milk-chocolate.png",
            "heading": "Private Label Confections",
            "subheading": "Custom Confectionery Solutions at Scale",
            "content": "<p><\/p><p><strong>Retail-Ready Assortments<\/strong><br\/>Proven flavor profiles and formats designed to perform across grocery, specialty, and club channels.<\/p><p><strong>Speed to Market<\/strong><br\/>Leverage established recipes and production capabilities to launch faster with less development risk.<\/p><p><strong>Flexible Packaging Options<\/strong><br\/>From stand-up pouches to seasonal gifting formats, tailored to your brand and shelf strategy.<\/p><p><strong>Premium Quality, Trusted Heritage<\/strong><br\/>Family-owned since 1939 with a reputation built on flavor, consistency, and craftsmanship.<\/p>",
            "button_text": "",
            "button_link": "",
            "alignment": "left"
          }
        },
        "block_gtzbr3": {
          "type": "block",
          "settings": {
            "image": "shopify:\/\/shop_images\/Packaging_Options.png",
            "heading": "Private Label Confections",
            "subheading": "Retail-Ready Assortments Built to Perform",
            "content": "<p><strong>Retail-Ready Assortments<\/strong><br\/>Proven flavor profiles and packaging formats designed for performance across grocery, club, and specialty retail.<\/p><p><strong>Speed to Market<\/strong><br\/>Leverage established formulations and scalable production to reduce development timelines and minimize risk.<\/p><p><strong>Flexible Packaging Options<\/strong><br\/>From stand-up pouches and tubs to seasonal gifting and multi-pack configurations, formats are tailored to your brand and shelf strategy.<\/p><p><strong>Premium Quality, Reliable Execution<\/strong><br\/>Backed by four generations of confectionery manufacturing expertise.<\/p>",
            "button_text": "",
            "button_link": "",
            "alignment": "left"
          }
        },
        "block_gwYHUJ": {
          "type": "block",
          "disabled": true,
          "settings": {
            "image": "shopify:\/\/shop_images\/Triple_Berry_b8c9c0dc-700e-482b-8259-b57909438e0e.png",
            "heading": "Capabilities",
            "subheading": "Private Label Manufacturing",
            "content": "<ul><li>Custom candy formulation and product development<\/li><li>Chocolate panning, moguel, and coated confections<\/li><li>Flavor innovation and ingredient sourcing<\/li><li>Multiple packaging formats and bag sizes<\/li><li>Retail-ready and club-ready production<\/li><li>Scalable manufacturing for regional or national distribution<\/li><\/ul><p><\/p>",
            "button_text": "",
            "button_link": "",
            "alignment": "left"
          }
        },
        "block_VG3ag7": {
          "type": "block",
          "settings": {
            "image": "shopify:\/\/shop_images\/Choc2.jpg",
            "heading": "Capabilities",
            "subheading": "Private Label Manufacturing",
            "content": "<p>As an <strong>experienced private label chocolate manufacturer<\/strong>, Sconza supports national retailers, club stores, and specialty brands with scalable confectionery production. Our vertically integrated manufacturing capabilities allow us to produce premium chocolate and panned confections that meet the quality, consistency, and volume requirements of large retail programs. <\/p><ul><li>Custom <strong>private label confectionery development<\/strong><\/li><li>Advanced <strong>chocolate panning and confectionery manufacturing expertise<\/strong><\/li><li>Flavor innovation and ingredient sourcing<\/li><li>Flexible <strong>private label packaging formats for retail distribution<\/strong><\/li><li>Scalable private label manufacturing for national retail distribution<\/li><\/ul><p><\/p>",
            "button_text": "",
            "button_link": "",
            "alignment": "left"
          }
        },
        "block_jN6bCw": {
          "type": "block",
          "settings": {
            "image": "shopify:\/\/shop_images\/MultRetailChannels.png",
            "heading": "Confectionery for multiple retail channels",
            "subheading": "Private Label",
            "content": "<p>Sconza's private label confectionery programs are designed to perform across a wide range of retail environments, including:<br\/><\/p><ul><li>Grocery retailers<\/li><li>Club stores<\/li><li>Specialty food retailers<\/li><li>Seasonal and promotional retail programs<\/li><\/ul>",
            "button_text": "",
            "button_link": "",
            "alignment": "left"
          }
        }
      },
