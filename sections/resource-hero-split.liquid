  <section class="hero hero--split hero--flip dots--outline arrows--circle">
    <div class="hero__slider">
      {% for block in section.blocks %}
      <div class="slick-protect">
        <div class="hero__slide d-flex">
          <div class="slide__content">
            <div class="content-wrap">
              <div class="inner">
                <h2 class="heading--hero">
                  {{ block.settings.heading }}
                </h2>
                <p>{{ block.settings.copy }}</p>
                <a href="{{ block.settings.button_url }}" class="btn btn--solid">{{ block.settings.button_text }}</a>
              </div>
            </div>
          </div>
          <img width="720" height="680" src="{{ block.settings.image | img_url: 'master' }}" class="slide__img" />
        </div>
      </div>
    {% endfor %}
    </div>
    <div class="split--dots"></div>
  </section>

{% schema %}
{
	"name": "Hero Split - Left",
  "blocks": [
		{
			"type": "text",
			"name": "Slide",
			"settings": [
        {
          "id": "image",
          "type": "image_picker",
          "label": "Image"
        },
        {
          "id": "mobile_image",
          "type": "image_picker",
          "label": "Mobile Image"
        },
        {
          "id": "heading",
          "type": "text",
          "label": "Heading"
        },
        {
          "id": "copy",
          "type": "richtext",
          "label": "Copy"
        },
        {
          "id": "button_text",
          "type": "text",
          "label": "Button Text"
        },
        {
          "id": "button_url",
          "type": "url",
          "label": "Button URL"
        }
			]
		}
	]
}
{% endschema %}