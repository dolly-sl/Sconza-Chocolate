<section class="tw-bg-backgroundDark tw-py-16 md:tw-py-[70px] lg:tw-pt-[85px] lg:tw-pb-[125px] tw-relative tw-z-0 tw-overflow-hidden">
  <img
    src="{{ 'choc-2.png' | asset_url }}"
    alt="choc"
    class="tw-absolute tw-left-1/4 tw-top-0 tw-size-16 md:tw-block tw-hidden tw--z-10">
  <img
    src="{{ 'almond-4.png' | asset_url }}"
    alt="almond"
    class="tw-absolute tw-right-20 tw-top-20 tw-size-24 md:tw-block tw-hidden tw--z-10">
  <img
    src="{{ 'shape.png' | asset_url }}"
    alt="shape"
    class="tw-absolute tw-lef-0 tw-top-28 md:tw-block tw-hidden tw--z-10">
  <img
    src="{{ 'vanilla-1.png' | asset_url }}"
    alt="vanilla"
    class="tw-absolute tw-left-1/4 tw-bottom-0 md:tw-block tw-hidden tw--z-10">
  <img
    src="{{ 'choc-3.png' | asset_url }}"
    alt="choc"
    class="tw-absolute tw-right-1/4 tw-bottom-0 tw-blur-sm md:tw-block tw-hidden tw--z-10">
  <div class="relative z-0 wrapper">
    <!-- Section Heading -->
    <div class="tw-text-center">
      <p class="tw-text-3xl md:tw-text-4xl tw-text-mainGold tw-font-script tw-mb-3">
        {{ section.settings.heading }}
      </p>
      <h2 class="tw-text-mainBlack2 tw-text-3xl md:tw-text-4xl tw-font-bold tw-uppercase tw-tracking-[0.338px] tw-font-osc lg:tw-block">
        {{ section.settings.subheading }}
      </h2>
    </div>
  </div>
  <div class="tw-relative tw-z-0 tw-px-10 tw-mt-16 md:tw-mt-20">
    <!-- Slider -->
    <div class="tw-w-full swiper timelineSwiper !tw-overflow-visible swiper-initialized swiper-horizontal swiper-backface-hidden">
      <!-- Swiper Wrapper -->
      <div
        class="swiper-wrapper"
        style="
          transition-duration: 0ms;
          transform: translate3d(0px, 0px, 0px);
          transition-delay: 0ms;
        "
        id="swiper-wrapper-72b176fa7ff20ec4"
        aria-live="polite">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'slide' -%}

              {% assign is_even = forloop.index | modulo: 2 %}
              <div
                class="swiper-slide {% if is_even == 0 %} -tw-mt-[30px]{% endif %}"
                style="width: 377.5px; margin-right: 46px"
                role="group"
                aria-label="1 / 6">
                <div class="tw-relative tw-z-0 tw-flex tw-flex-col tw-text-center tw-items-center tw-justify-center {% if block.settings.date == '1939' %}obj-top{% endif %}">
                  {%- assign image = block.settings.image -%}
                  {{
                    image | image_url: width: image.width | image_tag: class: 'tw-h-[250px] md:tw-h-[390px] tw-w-full tw-object-cover tw-mb-5', loading: 'lazy'
                  }}
                  <div class="tw-mt-2.5 sparkjoy-content">
                    <h2 class="tw-text-xl tw-text-mainBlack tw-uppercase tw-font-bold tw-font-osc">
                      {{ block.settings.date }}
                      <br>
                      {{ block.settings.title }}
                    </h2>
                    <p class="tw-text-sm tw-text-mainBlack tw-mt-3 tw-px-3 tw-text-left">
                      {{ block.settings.content }}
                    </p>
                  </div>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
      <span
        class="swiper-notification"
        aria-live="assertive"
        aria-atomic="true"></span>
    </div>
    <!-- Navigation Button -->
    <button
      type="button"
      class="tw-absolute tw-z-10 tw-top-[30%] tw-hidden tw--translate-y-1/2 tw-left-10 lg:tw-left-4 button-prev-6  md:tw-block swiper-button-disabled animate"
      tabindex="-1"
      aria-label="Previous slide"
      aria-controls="swiper-wrapper-72b176fa7ff20ec4"
      aria-disabled="true"
      disabled="disabled">
      <img src="{{ 'carousel-button-prev.svg' | asset_url }}" alt="button prev">
    </button>
    <button
      type="button"
      class="tw-absolute tw-z-10 tw-top-[30%] tw-hidden tw--translate-y-1/2 tw-right-10 lg:tw-right-4 button-next-6  md:tw-block animate"
      tabindex="0"
      aria-label="Next slide"
      aria-controls="swiper-wrapper-72b176fa7ff20ec4"
      aria-disabled="false">
      <img src="{{ 'carousel-button-next.svg' | asset_url }}" alt="button next">
    </button>
  </div>
</section>

{% schema %}
  {
    "name": "Timeline",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      }, {
        "type": "text",
        "id": "subheading",
        "label": "Subheading"
      }
    ],
    "blocks": [
      {
        "name": "Slide",
        "type": "slide",
        "settings": [
          {
            "type": "text",
            "id": "date",
            "label": "Date"
          }, {
            "type": "text",
            "id": "title",
            "label": "Title"
          }, {
            "type": "textarea",
            "id": "content",
            "label": "Content"
          }, {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Timeline"
      }
    ]
  }
{% endschema %}