{% if product.metafields.sleepless.about_content != blank %}
  <section class="tw-bg-backgroundLight tw-pt-16 md:tw-pt-[76px] tw-relative tw-overflow-hidden">
    <div class="tw-relative wrapper">
      <div class="tw-flex tw-items-center tw-justify-evenly tw-flex-col-reverse md:tw-flex-row tw-flex-wrap md:tw-flex-nowrap">
        <div class="tw-flex tw-flex-col tw-justify-center tw-w-full tw-text-left md:tw-w-auto">
          <h4 class="tw-text-xl md:tw-text-[30px] tw-leading-normal tw-font-script tw-text-mainGold tw-mb-2.5 lg:tw-mb-4">
            About This Product
          </h4>
          <h5 class="tw-text-mainBlack tw-text-[20px] md:tw-leading-[1.3] tw-font-bold tw-font-os tw-max-w-[400px]">
            {{ product.metafields.sleepless.about_content }}
          </h5>

          {% if product.metafields.custom.ingredients != blank %}
            <p class="tw-text-sm tw-text-mainBlack tw-mb-5 md:tw-mb-6 tw-max-w-[432px] tw-mt-10">
              <strong>Ingredients:
              </strong>
              {{ product.metafields.custom.ingredients }}
            </p>
          {% endif %}

          {% if product.metafields.custom.nutrition_facts != blank %}
            <button
              type="button"
              class="tw-text-left tw-underline animate"
              data-image="{{ product.metafields.custom.nutrition_facts }}">
              View Nutrition Facts
            </button>
          {% elsif product.metafields.sleepless.about_more_content_title != blank %}
            <button
              type="button"
              class="tw-text-left tw-underline animate js-open-modal tw-mt-4"
              data-content="{{ product.metafields.sleepless.about_more_content }}"
              data-modal-title="{{ product.metafields.sleepless.about_more_content_title }}">
              {{ product.metafields.sleepless.about_more_content_title }}
            </button>

            <div class="tw-fixed tw-inset-0 tw-bg-black tw-bg-opacity-50 tw-flex tw-items-center tw-justify-center tw-hidden" id="modal">
              <div class="tw-bg-white tw-rounded-lg tw-p-8 tw-max-w-md tw-w-full">
                <h2 class="tw-text-2xl tw-font-bold tw-mb-4 modal-title"></h2>
                <p class="tw-text-gray-700 tw-mb-6 modal-body"></p>
                <button class="tw-bg-mainGold tw-text-white tw-py-2 tw-px-4 tw-rounded tw-hover:bg-mainGold/80 tw-transition-colors modal-close">Close</button>
              </div>
            </div>

            <script>
              document.addEventListener('DOMContentLoaded', function() {
                var openModalButton = document.querySelector('.js-open-modal');
                var modal = document.getElementById('modal');
                var modalTitle = modal.querySelector('.modal-title');
                var modalBody = modal.querySelector('.modal-body');
                var closeModalButton = modal.querySelector('.modal-close');

                if (openModalButton) {
                  openModalButton.addEventListener('click', function() {
                    modalTitle.textContent = this.getAttribute('data-modal-title');
                    modalBody.textContent = this.getAttribute('data-content');
                    modal.classList.remove('tw-hidden');
                    document.body.style.overflow = 'hidden'; // Prevent scrolling when modal is open
                  });
                }

                function closeModal() {
                  modal.classList.add('tw-hidden');
                  document.body.style.overflow = ''; // Restore scrolling
                }

                if (closeModalButton) {
                  closeModalButton.addEventListener('click', closeModal);
                }

                // Close modal when clicking on the background overlay
                modal.addEventListener('click', function(event) {
                  if (event.target === modal) {
                    closeModal();
                  }
                });

                // Ensure modal is on top of all content
                modal.style.zIndex = '9999';
              });
            </script>
          {% endif %}
        </div>
        {% if product.metafields.sleepless.about_image != blank %}
          <div class="tw-block">
            {%- assign image = product.metafields.sleepless.about_image.value -%}
            {{ image | image_url: width: image.width | image_tag: class: 'tw-w-[650px]', loading: 'lazy' }}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
  {
    "name": "PDP About",
    "settings": [],
    "presets": [
      {
        "name": "PDP About"
      }
    ]
  }
{% endschema %}