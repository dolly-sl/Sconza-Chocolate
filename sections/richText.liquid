<section class="tw-bg-backgroundDark tw-py-14 md:tw-py-16 lg:tw-py-20 tw-relative tw-z-0 tw-overflow-hidden">
  <img
    src="{{ 'almond-3.png' | asset_url }}"
    alt="almond"
    class="tw-absolute tw-bottom-20 tw--left-10 tw--z-10 tw-hidden md:tw-block">
  <img
    src="{{ 'choc-2.png' | asset_url }}"
    alt="almond"
    class="tw-absolute tw--right-16 tw-top-1/2 tw--z-10 tw-hidden md:tw-block">
  <div class="wrapper tw-relative tw-z-0">
    <img
      src="{{ 'choc-vanilla-group.png' | asset_url }}"
      alt="choc"
      class="tw-absolute tw-top-0 tw-left-0 tw--z-10 tw-hidden md:tw-block">
    <img
      src="{{ 'shape.png' | asset_url }}"
      alt="choc"
      class="tw-absolute tw-top-0 tw-right-0 tw--z-10 tw-hidden md:tw-block">
    <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-text-center tw-max-w-3xl tw-mx-auto">
      {% if section.settings.heading != blank %}
        <h2 class="tw-text-mainBlack tw-text-4xl md:tw-text-4xl tw-uppercase tw-font-extrabold tw-font-osc tw-mb-4 md:tw-mb-5">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      {% if section.settings.content != blank %}
        <div class="tw-text-mainBlack tw-text-base tw-mb-7">
          {{ section.settings.content | raw }}
        </div>
      {% endif %}
      {% if section.settings.button_url != blank and section.settings.button_text != blank %}
        <a href="{{ section.settings.button_url }}" class="btn-primary md:tw-flex tw-hidden">
          {{- section.settings.button_text -}}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Rich Text",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      }, {
        "type": "richtext",
        "id": "content",
        "label": "Content"
      }, {
        "type": "text",
        "id": "button_text",
        "label": "Button Text"
      }, {
        "type": "url",
        "id": "button_url",
        "label": "Button URL"
      }
    ],
    "presets": [
      {
        "name": "Rich Text"
      }
    ]
  }
{% endschema %}
