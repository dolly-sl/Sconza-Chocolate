{% if product.metafields.sleepless.image_gallery != blank %}
  <section class=" tw-bg-backgroundDark tw-py-16 md:tw-py-[70px] lg:tw-py-[85px] tw-relative tw-z-0 tw-overflow-hidden">
    <img
      src="{{ 'vanilla-1.png' | asset_url }}"
      alt="vanilla"
      class="tw-absolute tw-bottom-0 tw-left-10 md:tw-left-1/3 tw--z-10 tw-blur-sm">
    <img
      src="{{ 'almond-3.png' | asset_url }}"
      alt="vanilla"
      class="tw-absolute tw-bottom-7 md:tw-bottom-0 tw-w-14 tw-right-20 tw--z-10 md:tw-w-auto">
    <div class="tw-relative tw-z-0 wrapper">
      <img
        src="{{ 'shape.png' | asset_url }}"
        alt="shape"
        class="tw-absolute tw-left-0 tw-z-10 tw--top-20 md:tw--top-24 md:tw-left-60">
      <img
        src="{{ 'choc-vanilla.png' | asset_url }}"
        alt="choc vanilla"
        class="tw-absolute tw-right-0 tw-w-28 tw--top-20 tw--z-10 md:tw-w-auto">
    </div>
    <div class="tw-relative tw-z-0">
      <div class="tw-w-full swiper socialSwiper !tw-overflow-visible">
        <div class="swiper-wrapper">
          {% assign images = product.metafields.sleepless.image_gallery.value %}

          {%- for image in images -%}
            {% assign is_even = forloop.index | modulo: 2 %}
            <div class="swiper-slide tw-group {% if is_even == 0 %} -tw-mt-[30px]{% endif %}">
              <div class="tw-relative tw-z-0 tw-flex tw-flex-col tw-text-center tw-items-center tw-justify-center tw-w-full tw-h-[210px] md:tw-h-[388px]">
                {{
                  image | image_url: width: image.width | image_tag: class: 'tw-object-cover tw-w-full tw-h-full', loading: 'lazy'
                }}
                {% if template.name == 'index' %}
                  <a
                    href="{{ block.settings.link }}"
                    target="_blank"
                    class="tw-absolute tw-top-0 tw-left-0 tw-flex tw-flex-col tw-items-center tw-justify-center tw-transition-all tw-duration-300 tw-ease-in-out tw-rounded tw-opacity-0 tw-bg-black/40 tw-w-full tw-h-full group-hover:tw-opacity-100">
                    <img src="{{ 'instagram.svg' | asset_url }}" alt="instagram">
                  </a>
                {% endif %}
              </div>
            </div>
          {%- endfor -%}
          {%- for image in images -%}
            {% assign is_even = forloop.index | modulo: 2 %}
            <div class="swiper-slide tw-group {% if is_even == 0 %} -tw-mt-[30px]{% endif %}">
              <div class="tw-relative tw-z-0 tw-flex tw-flex-col tw-text-center tw-items-center tw-justify-center tw-w-full tw-h-[210px] md:tw-h-[388px]">
                {{
                  image | image_url: width: image.width | image_tag: class: 'tw-object-cover tw-w-full tw-h-full', loading: 'lazy'
                }}
                {% if template.name == 'index' %}
                  <a
                    href="{{ block.settings.link }}"
                    target="_blank"
                    class="tw-absolute tw-top-0 tw-left-0 tw-flex tw-flex-col tw-items-center tw-justify-center tw-transition-all tw-duration-300 tw-ease-in-out tw-rounded tw-opacity-0 tw-bg-black/40 tw-w-full tw-h-full group-hover:tw-opacity-100">
                    <img src="{{ 'instagram.svg' | asset_url }}" alt="instagram">
                  </a>
                {% endif %}
              </div>
            </div>
          {%- endfor -%}


        </div>
      </div>
      <button type="button" class="tw-absolute tw-z-10 tw-hidden tw--translate-y-1/2 tw-left-10 lg:tw-left-20 button-prev-99 tw-top-1/2 md:tw-block animate">
        <img src="{{ 'carousel-button-prev.svg' | asset_url }}" alt="button prev">
      </button>
      <button type="button" class="tw-absolute tw-z-10 tw-hidden tw--translate-y-1/2 tw-right-10 lg:tw-right-20 button-next-99 tw-top-1/2 md:tw-block animate">
        <img src="{{ 'carousel-button-next.svg' | asset_url }}" alt="button next">
      </button>
    </div>
  </section>
{% endif %}

{% schema %}
  {
    "name": "PDP Image Carousel",
    "settings": [],
    "presets": [
      {
        "name": "PDP Image Carousel"
      }
    ]
  }
{% endschema %}