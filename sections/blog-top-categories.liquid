{% comment %}
  Section: blog-top-categories.liquid
  Use on: Blog listing page and main blog page
  Slider: Swiper.js (already loaded via theme)
{% endcomment %}

<section class="top-categories-section tw-pb-20 tw-bg-backgroundDark">
  <div class="tw-container container-1420 tw-mx-auto tw-px-4">

    {% if section.settings.title != blank %}
      <h2 class="top-categories-section__title tw-text-[35px] tw-font-bold tw-font-osc tw-uppercase tw-text-center">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="top-categories-section__wrapper tw-relative">

      <!-- Navigation Buttons -->
      <button
        type="button"
        class="tw-absolute tw-z-10 tw-top-[40%] tw-hidden tw--translate-y-1/2 tw-left-10 lg:tw-left-4 button-prev-categories md:tw-block animate"
        tabindex="-1"
        aria-label="Previous slide"
        aria-disabled="true">
        <img src="{{ 'carousel-button-prev.svg' | asset_url }}" alt="button prev">
      </button>

      <button
        type="button"
        class="tw-absolute tw-z-10 tw-top-[40%] tw-hidden tw--translate-y-1/2 tw-right-10 lg:tw-right-4 button-next-categories md:tw-block animate"
        tabindex="0"
        aria-label="Next slide"
        aria-disabled="false">
        <img src="{{ 'carousel-button-next.svg' | asset_url }}" alt="button next">
      </button>

      <!-- Swiper -->
      <div class="swiper top-categories-swiper">
        <div class="swiper-wrapper">

          {% for block in section.blocks %}
            {% if block.type == 'category_card' %}
              <div class="swiper-slide top-categories-section__slide" {{ block.shopify_attributes }}>

                <div class="image-section">
                  {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" class="top-categories-section__image-link" aria-label="{{ block.settings.card_title }}">
                  {% endif %}

                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.card_title | escape }}"
                      loading="lazy"
                      width="600"
                      height="400"
                      class="top-categories-section__img">
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'top-categories-section__img top-categories-section__placeholder' }}
                  {% endif %}

                  {% if block.settings.link != blank %}
                    </a>
                  {% endif %}
                </div>

                {% if block.settings.card_title != blank %}
                  <h3 class="top-categories-section__card-title">
                    {% if block.settings.link != blank %}
                      <a href="{{ block.settings.link }}">{{ block.settings.card_title }}</a>
                    {% else %}
                      {{ block.settings.card_title }}
                    {% endif %}
                  </h3>
                {% endif %}

              </div>
            {% endif %}
          {% endfor %}

        </div>

        <!-- Pagination (mobile) -->
        <div class="swiper-pagination top-categories-swiper-pagination"></div>
      </div>

    </div>
  </div>
</section>

<style>
  .top-categories-section__title {
    margin-bottom: 50px;
  }

  .top-categories-section__wrapper {
    position: relative;
  }

  .top-categories-section__slide {
    display: flex;
    flex-direction: column;
  }

  .top-categories-section__slide .image-section {
    overflow: hidden;
    height: calc(11.1vw - 25px);
    display: block;
  }

  .top-categories-section__slide .image-section a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .top-categories-section__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .image-section:hover .top-categories-section__img {
    transform: scale(1.04);
  }

  .top-categories-section__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .top-categories-section__card-title {
    font-size: 20px;
    font-weight: 800;
    text-transform: uppercase;
    text-align: center;
    color: #1E1C1C;
    margin-top: 15px;
  }

  .top-categories-section__card-title a {
    color: inherit;
    text-decoration: none;
  }

  .top-categories-section__card-title a:hover {
    text-decoration: underline;
  }

  /* Pagination dots – visible mobile only */
  .top-categories-swiper-pagination {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
    width: 8px;
    height: 8x;
    padding: 0 6px;
  }
  .top-categories-swiper .swiper-pagination-bullet {
    background: transparent;
    border: 1px solid #000000;
    opacity: 1;
  }
  .top-categories-swiper .swiper-pagination-bullet-active {
    background: #000000;
  }
  .top-categories-section__wrapper .button-prev-categories, 
  .top-categories-section__wrapper .button-next-categories {
    top: 41%;
  }
  .top-categories-section__wrapper .button-prev-categories {
    left: -20px;
  }
  .top-categories-section__wrapper .button-next-categories {
    right: -20px;
  }
  @media (min-width: 768px) {
    .top-categories-swiper-pagination {
      display: none;
    }
  }
  @media (max-width: 2500px) {
    .top-categories-section__slide .image-section {
      height: calc(14.1vw - 25px);
    }
  }
  @media (max-width: 1920px) {
    .top-categories-section__slide .image-section {
      height: calc(16.1vw - 25px);
    }
  }
  @media (max-width: 1560px) {
    .top-categories-section__slide .image-section {
      height: calc(22.1vw - 25px);
    }
  }
  @media (max-width: 1280px) {
    .top-categories-section__slide .image-section {
      height: calc(20.1vw - 25px);
    }
  }
  @media (max-width: 1100px) {
    .top-categories-section__slide .image-section {
        height: calc(22.1vw - 25px);
    }
  }
  @media (max-width: 768px) {
    .top-categories-section__title {
      margin: 30px 0 44px 0;
      line-height: 42px;
    }
    .top-categories-section__slide .image-section {
      height: calc(83vw - 10px);
    }
    .top-categories-section__slide {
      padding-bottom: 60px;
    }
    #shopify-section-blog-list .blog__tags .desktop-wrap {
      display: flex;
    }
    #shopify-section-blog-list .blog__tags .mobile-wrap {
      display: none;
    }
    .top-categories-section {
      padding-bottom: 50px;
    }
  }
</style>

<script>
  (function () {
    var el = document.querySelector('.top-categories-swiper');
    if (!el) return;

    var swiper = new Swiper('.top-categories-swiper', {
      slidesPerView: 1,
      spaceBetween: 16,
      grabCursor: true,
      navigation: {
        prevEl: '.button-prev-categories',
        nextEl: '.button-next-categories',
      },
      pagination: {
        el: '.top-categories-swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        480: {
          slidesPerView: 1,
          spaceBetween: 16,
        },
        768: {
          slidesPerView: 3.5,
          spaceBetween: 20,
        },
        1024: {
          slidesPerView: 4,
          spaceBetween: 20,
        },
      },
    });
  })();
</script>

{% schema %}
{
  "name": "Top Categories Slider",
  "tag": "section",
  "class": "top-categories-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Explore Our Top Categories"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top Categories Slider",
      "blocks": [
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 1"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 2"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 3"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
