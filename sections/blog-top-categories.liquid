{% comment %}
  Section: blog-top-categories.liquid
  Use on: Blog listing page and main blog page
  Slider: Swiper.js (already loaded via theme)
{% endcomment %}

<section class="top-categories-section tw-pb-20 tw-bg-backgroundDark">
  <div class="tw-container container-1420 tw-mx-auto tw-px-4">

    {% if section.settings.title != blank %}
      <h2 class="top-categories-section__title tw-text-[35px] tw-font-bold tw-font-osc tw-uppercase tw-text-center">{{ section.settings.title }}</h2>
    {% endif %}

    {% assign category_blocks = section.blocks | where: 'type', 'category_card' %}
    {% assign block_count = category_blocks | size %}

    <div class="top-categories-section__wrapper tw-relative">

      <!-- Navigation Buttons (only show if more than 4 cards) -->
      {% if block_count > 4 %}
        <button
          type="button"
          class="tw-absolute tw-z-10 tw-top-[40%] tw-hidden tw--translate-y-1/2 tw-left-10 lg:tw-left-4 button-prev-categories md:tw-block animate"
          tabindex="-1"
          aria-label="Previous slide"
          aria-disabled="true">
          <img src="{{ 'carousel-button-prev.svg' | asset_url }}" alt="button prev">
        </button>

        <button
          type="button"
          class="tw-absolute tw-z-10 tw-top-[40%] tw-hidden tw--translate-y-1/2 tw-right-10 lg:tw-right-4 button-next-categories md:tw-block animate"
          tabindex="0"
          aria-label="Next slide"
          aria-disabled="false">
          <img src="{{ 'carousel-button-next.svg' | asset_url }}" alt="button next">
        </button>
      {% endif %}

      <!-- Swiper -->
      <div class="swiper top-categories-swiper {% if block_count <= 3 %}is-centered{% endif %}">
        <div class="swiper-wrapper">

          {% for block in section.blocks %}
            {% if block.type == 'category_card' %}
              <div class="swiper-slide top-categories-section__slide" {{ block.shopify_attributes }}>

                <div class="image-section">
                  {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" class="top-categories-section__image-link" aria-label="{{ block.settings.card_title }}">
                  {% endif %}

                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.card_title | escape }}"
                      loading="lazy"
                      width="600"
                      height="400"
                      class="top-categories-section__img">
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'top-categories-section__img top-categories-section__placeholder' }}
                  {% endif %}

                  {% if block.settings.link != blank %}
                    </a>
                  {% endif %}
                </div>

                {% if block.settings.card_title != blank %}
                  <h3 class="top-categories-section__card-title">
                    {% if block.settings.link != blank %}
                      <a href="{{ block.settings.link }}">{{ block.settings.card_title }}</a>
                    {% else %}
                      {{ block.settings.card_title }}
                    {% endif %}
                  </h3>
                {% endif %}

              </div>
            {% endif %}
          {% endfor %}

        </div>

        <!-- Pagination (mobile) -->
        <div class="swiper-pagination top-categories-swiper-pagination"></div>
      </div>

    </div>
  </div>
</section>


<script>
  (function () {
    var el = document.querySelector('.top-categories-swiper');
    if (!el) return;

    var blockCount = {{ block_count }};

    var swiper = new Swiper('.top-categories-swiper', {
      slidesPerView: 1,
      spaceBetween: 16,
      grabCursor: true,
      navigation: blockCount > 4 ? {
        prevEl: '.button-prev-categories',
        nextEl: '.button-next-categories',
      } : false,
      pagination: {
        el: '.top-categories-swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        480: {
          slidesPerView: 1,
          spaceBetween: 16,
        },
        600: {
          slidesPerView: 1.8,
          spaceBetween: 20,
        },
        768: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
        800: {
          slidesPerView: 3,
          spaceBetween: 20,
        },
        1024: {
          slidesPerView: 4,
          spaceBetween: 20,
        },
      },
    });
  })();
</script>

{% schema %}
{
  "name": "4 Card Slider",
  "tag": "section",
  "class": "top-categories-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "info": "Main heading displayed above the card slider. Defaults to 'Explore Our Top Categories' if left unchanged.",
      "default": "Explore Our Top Categories"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image",
          "info": "Upload or select an image to represent this category. Recommended to use consistent dimensions across all cards for a uniform slider appearance."
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "info": "The category name displayed on or below the card. Keep it short and descriptive (e.g. 'Living Room', 'Outdoor Furniture').",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link",
          "info": "URL the card navigates to when clicked. Link to a collection, page, or any relevant destination."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "4 Card Slider",
      "blocks": [
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 1"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 2"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 3"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "card_title": "Category 4"
          }
        }
      ]
    }
  ]
}
{% endschema %}