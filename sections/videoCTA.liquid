  <section class="tw-relative tw-z-0 tw-bg-[url('../img/stories-bg.png')] tw-bg-no-repeat tw-bg-cover before:tw-absolute before:tw-left-0 before:tw-top-0 before:tw-size-full before:tw--z-10 before:tw-bg-mainBlack/[.3]">
