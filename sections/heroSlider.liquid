<!-- Hero Section -->
<section class="tw-relative">
  <div class="tw-w-full swiper heroSwiper">
    <style>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {%- when 'slide' -%}
        {%- assign image = block.settings.image -%}
        {%- assign mobile_image = block.settings.mobile_image -%}
        .slide-{{ forloop.index }} {
          background-image: url('{{ image | image_url: width: image.width }}');
          background-size: cover;
          background-position: center;
          background-repeat: no-repeat;
        }
        @media (max-width: 767px) {
          .slide-{{ forloop.index }} {
            background-image: url('{{ mobile_image | image_url: width: mobile_image.width }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
          }
        }
      {%- endcase -%}
    {%- endfor -%}
    </style>
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'slide' -%}
            <div class="swiper-slide slide-{{ forloop.index }}" {{ block.shopify_attributes }}>
              {%- assign image = block.settings.image -%}
              {%- assign mobile_image = block.settings.mobile_image -%}
              <div class="tw-relative tw-z-0 before:tw-absolute before:tw-left-0 before:tw-top-0 before:tw-h-full before:tw-w-full before:tw-mix-blend-multiply">
                <div class="wrapper">
                  <div class="tw-flex tw-flex-col tw-items-start tw-justify-start
                                        {% case block.settings.text_position %}
                                            {% when 'top_left', 'top_center', 'top_right' %} md:tw-justify-start
                                            {% when 'middle_left', 'middle_center', 'middle_right' %} md:tw-justify-center
                                            {% when 'bottom_left', 'bottom_center', 'bottom_right' %} md:tw-justify-end
                                        {% endcase %}
                                        {% case block.settings.text_position_mobile %}
                                            {% when 'top_left', 'top_center', 'top_right' %} tw-justify-start
                                            {% when 'middle_left', 'middle_center', 'middle_right' %} tw-justify-center
                                            {% when 'bottom_left', 'bottom_center', 'bottom_right' %} tw-justify-end
                                        {% endcase %}
                                        tw-h-[600px] lg:tw-h-[719px] tw-relative tw-z-0 tw-px-0 tw-w-full">
                    <div class="tw-flex tw-flex-col tw-mt-[80px] tw-w-full
                                            {% case block.settings.text_position %}
                                                {% when 'top_left', 'top_center', 'top_right' %} md:tw-mt-[50px]
                                                {% when 'middle_left', 'middle_center', 'middle_right' %} md:tw-mt-0
                                                {% when 'bottom_left', 'bottom_center', 'bottom_right' %} md:tw-mb-[50px]
                                            {% endcase %}
                                            {% case block.settings.text_position_mobile %}
                                                {% when 'top_left', 'top_center', 'top_right' %} tw-mt-[50px]
                                                {% when 'middle_left', 'middle_center', 'middle_right' %} tw-mt-0
                                                {% when 'bottom_left', 'bottom_center', 'bottom_right' %} tw-mb-[50px]
                                            {% endcase %}
                                            {% case block.settings.text_position %}
                                                {% when 'top_left', 'middle_left', 'bottom_left' %} md:tw-items-start md:tw-text-left
                                                {% when 'top_center', 'middle_center', 'bottom_center' %} md:tw-items-center md:tw-text-center
                                                {% when 'top_right', 'middle_right', 'bottom_right' %} md:tw-items-end md:tw-text-right
                                            {% endcase %}
                                            {% case block.settings.text_position_mobile %}
                                                {% when 'top_left', 'middle_left', 'bottom_left' %} tw-items-start tw-text-left
                                                {% when 'top_center', 'middle_center', 'bottom_center' %} tw-items-center tw-text-center
                                                {% when 'top_right', 'middle_right', 'bottom_right' %} tw-items-end tw-text-right
                                            {% endcase %}
                                        ">
                      {% if block.settings.subheading != blank %}
                        <h3 class="tw-text-base md:tw-text-3xl {% if block.settings.text_black %}tw-text-black{% else %}tw-text-mainCream{% endif %} tw-capitalize tw-font-extrabold tw-font-osc tw-leading-none">
                          {{ block.settings.subheading }}
                        </h3>
                      {% endif %}
                      {% if block.settings.heading != blank %}
                        <h1 class="tw-text-4xl md:tw-mt-0 tw-mt-2 md:tw-text-[60px] lg:tw-text-[80px] tw-uppercase {% if block.settings.text_black %}tw-text-black{% else %}tw-text-mainWhite{% endif %} tw-font-osc tw-font-extrabold tw-leading-none">
                          {{ block.settings.heading }}
                        </h1>
                      {% endif %}
                      {% if block.settings.content != blank %}
                        <p class="tw-text-base tw-font-bold {% if block.settings.text_black %}tw-text-black{% else %}tw-text-white{% endif %} tw-w-[288px] md:tw-w-[413px] tw-mt-2.5 md:tw-mt-0">
                          {{ block.settings.content }}
                        </p>
                      {% endif %}
                      {% if block.settings.button_link != blank and block.settings.button_text != blank %}
                        <div class="md:tw-mt-10 tw-mt-5">
                          <a href="{{ block.settings.button_link }}" class="btn-primary">
                            {{- block.settings.button_text -}}
                          </a>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>


  <div class="tw-w-full tw-max-w-screen-xl tw-absolute tw-top-1/2 tw-left-1/2 tw--translate-x-1/2 tw-z-10 lg:tw-block tw-hidden">
    <!-- Navigation Button -->
    <button type="button" class="tw-absolute lg:tw-left-0 xl:-tw-left-6 tw-z-10 tw--translate-y-1/2 button-prev tw-top-1/2 animate">
      <img src="{{ 'carousel-button-prev.svg' | asset_url }}" alt="button prev">
    </button>
    <button type="button" class="tw-absolute lg:tw-right-0 xl:-tw-right-6 tw-z-10 tw--translate-y-1/2 button-next tw-top-1/2 animate">
      <img src="{{ 'carousel-button-next.svg' | asset_url }}" alt="button next">
    </button>
  </div>
  <!-- Pagination -->
  <div class="tw-absolute tw-z-10 tw-flex tw-items-center tw-justify-center tw-gap-2 tw-mb-5 hero-pagination"></div>
</section>

