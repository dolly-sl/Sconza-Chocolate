{% if section.blocks != blank %}
  <section class="tw-bg-backgroundLight tw-py-10">
    <div class="tw-container tw-relative">
      <div class="swiper bundleSlider">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {%- assign image = block.settings.image -%}
            {% if image != blank %}
              <div class="swiper-slide">
                {{ image | image_url: width: image.width | image_tag: class: 'add_your_class_here', loading: 'lazy' }}

                <h6 class="tw-uppercase tw-text-xs tw-font-bold tw-text-mainBlack tw-text-center tw-opacity-50 tw-mt-5">
                  {{ block.settings.subheading }}
                </h6>

                <h4 class="tw-text-xl tw-font-bold tw-text-mainBlack tw-text-center tw-mt-1 tw-mb-3">
                  {{ block.settings.heading }}
                </h4>

                <p class="tw-text-sm tw-text-mainBlack tw-text-center">{{ block.settings.content }}</p>

                {%- assign nutrition_facts = block.settings.nutrition_facts -%}
                {% if nutrition_facts != blank %}
                  <button type="button" class="tw-underline animate tw-text-mainBlack tw-text-center tw-mt-5 tw-mx-auto tw-w-full">
                    View Ingredients & Nutrition Facts
                  </button>
                  {{
                    nutrition_facts | image_url: width: nutrition_facts.width | image_tag: class: 'add_your_class_here', loading: 'lazy'
                  }}
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <button type="button" class="tw-absolute tw-z-10 tw-hidden tw--translate-y-1/2 tw-left-10 lg:tw-left-0 button-prev-8 tw-top-1/2 md:tw-block">
        <img src="{{ 'carousel-button-prev-2.svg' | asset_url }}" alt="button prev">
      </button>
      <button type="button" class="tw-absolute tw-z-10 tw-hidden tw--translate-y-1/2 tw-right-10 lg:tw-right-0 button-next-8 tw-top-1/2 md:tw-block">
        <img src="{{ 'carousel-button-next-2.svg' | asset_url }}" alt="button next">
      </button>
    </div>
  </section>
{% endif %}

{% schema %}
  {
    "name": "Bundle Slider",
    "settings": [],
    "blocks": [
      {
        "name": "Slide",
        "type": "slide",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "subheading",
            "label": "Subheading"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "textarea",
            "id": "content",
            "label": "Content"
          }, {
            "type": "image_picker",
            "id": "nutrition_facts",
            "label": "Nutrition Facts"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Bundle Slider"
      }
    ]
  }
{% endschema %}