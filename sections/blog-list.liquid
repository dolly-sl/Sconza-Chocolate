{%- comment -%}
  Shopify Liquid does not expose query string params on the `request` object,
  so detect ?sort=oldest by parsing the page URL out of content_for_header.
{%- endcomment -%}
{%- assign _ch_parts = content_for_header | split: '"pageurl":"' -%}
{%- assign _page_url = _ch_parts[1] | default: '' | split: '"' | first | default: '' -%}
{%- if _page_url contains 'sort=oldest' -%}
  {%- assign is_oldest = true -%}
  {%- assign sort_query = '?sort=oldest' -%}
{%- else -%}
  {%- assign is_oldest = false -%}
  {%- assign sort_query = '' -%}
{%- endif -%}

<section class="blog__list tw-font-os">
  <div class="tw-container container-1420">
    <div class="article__wrap d-flex">
      <div class="blog__tags">
        <div class="desktop-wrap">
          <div class="blog__tags-header d-flex align-center justify-between">
            <h2 class="tw-text-mainBlack2 tw-text-[35px] tw-font-bold tw-font-osc tw-uppercase tw-text-left">
              Recent Posts
            </h2>

            <div class="blog__filters d-flex align-center">

              <div class="blog__filter-select">
                <select id="sortBy" class="custom-dropdown-select dropdown-select">
                  <option value="newest" {% unless is_oldest %}selected{% endunless %}>
                    Newest First
                  </option>

                  <option value="oldest" {% if is_oldest %}selected{% endif %}>
                    Oldest First
                  </option>

                </select>
              </div>

              <!-- CATEGORY SNIPPET -->
              {% render 'blog_category' %}

            </div>
          </div>
        </div>

        <div class="mobile-wrap">
          <div class="form__group">
            <label class="sr-only">Choose Category</label>
            <select onchange="if(this.value) window.location.href = this.value;">
              <option
                {% unless current_tags != blank %}
                selected
                {% endunless %}
                value="{{ blog.url }}{{ sort_query }}">
                View All
              </option>

              {% for tag in blog.all_tags %}
                <option
                  {% if current_tags contains tag %}selected{% endif %}
                  value="{{ blog.url }}/tagged/{{ tag | handleize }}{{ sort_query }}">
                  {{ tag }}
                </option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>

      {%- paginate blog.articles by section.settings.posts_per_page -%}

        <div id="blog__articles-list" class="blog__articles-list">
          {% for article in blog.articles %}
            {% render 'default-article', data: article %}
          {% endfor %}
        </div>

        <div class="d-flex justify-between blog__toolbar  md:tw-m-0 tw-mx-10">
          <div class="page-count d-flex align-center">
            Showing items {{ paginate.current_offset | plus: 1 }}-
            {%- if paginate.next -%}
              {{ paginate.current_offset | plus: paginate.page_size }}
            {%- else -%}
              {{ paginate.items }}
            {%- endif %}
            of {{ paginate.items }}
          </div>

          <div class="pagination">
            <div class="tw-container container-1420">
              <ul class="d-flex list-reset align-center blog__pagination-list">
                {% for part in paginate.parts %}
                  <li class="blog__pagination-item{% if part.title == paginate.current_page %} current{% endif %}">
                    {% if part.is_link %}
                      <a href="{{ part.url }}" class="blog__pagination-link animate">{{ part.title }}</a>
                    {% elsif part.title == '&hellip;' %}
                      <span class="blog__pagination-ellipsis">&hellip;</span>
                    {% else %}
                      <span class="blog__pagination-link blog__pagination-current">{{ part.title }}</span>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>

        <style>
          .blog__pagination-list { gap: 4px; }

          .blog__pagination-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 28px;
            font-size: 14px;
            color: #1E1C1C;
            text-decoration: none;
            border-radius: 3px;  
          }

          .blog__pagination-link:hover { color: #A79E89; }

          .blog__pagination-item.current .blog__pagination-link,
          .blog__pagination-current {
            font-weight: 700;
          }
          .blog__toolbar .pagination ul li a {
            width: auto;
            height: auto;
          }
          .page-count { font-size: 14px; }
        </style>

      {% endpaginate %}
    </div>
  </div>
</section>

<style>
  .container-1420 {
    max-width: 1400px;
    padding: 0 30px;
  }

  .desktop-wrap {
    border-bottom: 1px solid #A79E8999;
    padding-bottom: 40px;
  }

  .blog__tags {
    width: 100%;
    padding: 0 15px 57px;
  }

  .blog__tags-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .blog__filters {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .blog__filter-select select {
    border: 1px solid #1E1C1C;
    min-width: 287px;
    height: 45px;
  }

  .blog__filter-select select:focus {
    outline: none;
    border-color: #A79E89;
  }
  .blog__list {
    background: #FFFCF3;
    padding-top: 60px;
    padding-bottom: 88px;
  }
  .blog__toolbar {
    border-top: 1px solid rgba(167, 158, 137, 0.60);
    border-bottom: 1px solid rgba(167, 158, 137, 0.60);
    padding: 31px 42px;
  }
  .custom-dropdown-select {
      border-color: #1E1C1C;
      max-width: 287px;
      height: 45px;
      background-color: transparent;
  }
  @media (max-width: 980px) {
    .custom-dropdown-select {
      max-width: 200px;
    }
    .blog__filter-select select {
      min-width: 200px;
    }
    .blog__toolbar {
        padding: 15px 42px;
    }
  }
  @media (max-width: 768px) {
    .blog__filters {
      margin-top: 50px;
    }
    .blog__filter-select, .custom-dropdown-select {
      width: 50%;
    }
   .blog__filter-select select {
      min-width: 100%;
    }
    .custom-dropdown-select {
      max-width: 50%;
      width: 50%;
    }
    .blog__tags .desktop-wrap {
      padding-bottom: 35px;
      border-bottom: 0;
    }
    .blog__tags {
      padding-bottom: 0;
    }
    {% comment %} .article__image img {
      height: calc(42.1vw - 20px);
    } {% endcomment %}
    .article--default {
        margin-bottom: 60px;
    }
    .blog__toolbar {
      border-bottom: 0;
      padding: 23px 0 0 0;
      margin: 0 10px;
    }
    .blog__toolbar .page-count {
      margin-bottom: 15px;
    }
    .blog__filter-select, .dropdown-select {
      width: 48%;
    }
    .blog__list {
      padding-bottom: 60px;
    }
  }
</style>

<script>
(function () {
  var sortByEl = document.getElementById('sortBy');
  if (!sortByEl) return;

  // Stop the global `.blog__tags select` change handler (in the theme bundle)
  // from treating our sort value ("newest"/"oldest") as a navigation URL.
  sortByEl.addEventListener('change', function (e) {
    e.stopImmediatePropagation();

    var sort = this.value;
    var url = new URL(window.location.href);
    url.searchParams.delete('sort');
    url.searchParams.delete('page');

    if (sort === 'oldest') {
      url.searchParams.set('sort', 'oldest');
    }

    window.location.href = url.toString();
  }, true);
})();
</script>
{% schema %}
{
  "name": "Blog List",
  "settings": [
    {
      "id": "posts_per_page",
      "type": "number",
      "label": "Articles / Page",
      "default": 12
    }
  ]
}
{% endschema %}