<section class="blog__list tw-font-os tw-mt-20 tw-pt-0">
  <div class="tw-container">
    <div class="article__wrap d-flex">
      <div class="blog__tags">
        <div class="desktop-wrap">
          <div class="blog__tags-header d-flex align-center justify-between">
            <h2 class="tw-text-mainBlack2 tw-text-[35px] tw-font-bold tw-font-osc tw-uppercase tw-text-left">
              Recent Posts
            </h2>
            <div class="blog__filters d-flex align-center" style="gap: 12px;">

              <!-- Sort By Dropdown -->
              <div class="form__group blog__filter-select">
                <label class="sr-only">Sort By</label>
                <select id="blog-sort-select">
                  <option value="" disabled selected>Sort By</option>
                  <option value="date-desc">Newest First</option>
                  <option value="date-asc">Oldest First</option>
                  <option value="title-asc">Title A–Z</option>
                  <option value="title-desc">Title Z–A</option>
                </select>
              </div>

              <!-- View All Articles / Filter by Tag Dropdown -->
              <div class="form__group blog__filter-select">
                <label class="sr-only">Filter Articles</label>
                <select id="blog-tag-select" onchange="if(this.value) window.location.href = this.value;">
                  <option value="/blogs/news" {% unless current_tags != blank %}selected{% endunless %}>
                    View All Articles
                  </option>
                  {% for tag in blog.all_tags %}
                    <option
                      value="/blogs/news/tagged/{{ tag | handleize }}"
                      {% if current_tags contains tag %}selected{% endif %}>
                      {{ tag }}
                    </option>
                  {% endfor %}
                </select>
              </div>

            </div>
          </div>
        </div>

        <div class="mobile-wrap">
          <div class="form__group">
            <label class="sr-only">Choose Category</label>
            <select onchange="if(this.value) window.location.href = this.value;">
              <option
                {% unless current_tags != blank %}
                selected
                disabled
                {% endunless %}
                value="/blogs/news">
                View All
              </option>
              {% for tag in blogs.news.all_tags %}
                <option
                  {% if current_tags contains tag %}
                  selected
                  disabled
                  {% endif %}
                  value="/blogs/news/tagged/{{ tag | handleize }}">
                  {{ tag }}
                </option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>

      {%- paginate blog.articles by section.settings.posts_per_page -%}
        <div id="blog-articles-wrapper">
          {% for article in blog.articles %}
            {% render 'default-article', data: article %}
          {% endfor %}
        </div>

        <div class="d-flex justify-between blog__toolbar tw-bg-white tw-p-6 md:tw-m-0 tw-mx-10">
          <div class="page-count d-flex align-center">
            Showing {{ paginate.current_offset | plus: 1 }}-
            {%- if paginate.next -%}
              {{- paginate.current_offset | plus: paginate.page_size -}}
            {%- else -%}
              {{- paginate.items -}}
            {%- endif %}
            of {{ paginate.items }} items
          </div>
          <div class="pagination">
            <div class="tw-container container-1420">
              <ul class="d-flex list-reset align-center">
                {% for part in paginate.parts %}
                  <li
                    {% if part.title == paginate.current_page %}
                    class="current"
                    {% endif %}>
                    {% if part.is_link %}
                      <a href="{{ part.url }}" class="animate">{{ part.title }}</a>
                    {% else %}
                      <span class="num">{{ part.title }}</span>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      {% endpaginate %}

    </div>
  </div>
</section>

<style>
  .container-1420 {
    max-width: 1420px;
    padding: 0 40px;
  }
  .desktop-wrap {
    border-bottom: 1px solid #A79E8999;
    padding-bottom: 40px;
  }
  .blog__tags {
    width: 100%;
    padding: 0 15px 57px;
  }

  /* New styles — filter row only */
  .blog__tags-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .blog__filters {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .blog__filter-select select {
    appearance: auto;
    -webkit-appearance: auto;
    border: 1px solid #ccc;
    border-radius: 4px;
    padding: 8px 32px 8px 14px;
    font-size: 14px;
    font-family: inherit;
    color: #1a1a1a;
    background-color: #fff;
    cursor: pointer;
    min-width: 160px;
  }
  .blog__filter-select select:focus {
    outline: none;
    border-color: #A79E89;
  }
</style>

<script>
  (function () {
    var sortSelect = document.getElementById('blog-sort-select');
    if (!sortSelect) return;

    // Restore sort selection from sessionStorage on page load
    var savedSort = sessionStorage.getItem('blog-sort');
    if (savedSort) sortSelect.value = savedSort;

    sortSelect.addEventListener('change', function () {
      var sortValue = this.value;
      sessionStorage.setItem('blog-sort', sortValue);

      var wrapper = document.getElementById('blog-articles-wrapper');
      if (!wrapper) return;

      // Collect all article cards
      var articles = Array.from(wrapper.children);

      articles.sort(function (a, b) {
        if (sortValue === 'date-desc' || sortValue === 'date-asc') {
          var dateA = new Date(a.dataset.date || 0);
          var dateB = new Date(b.dataset.date || 0);
          return sortValue === 'date-desc' ? dateB - dateA : dateA - dateB;
        }
        if (sortValue === 'title-asc' || sortValue === 'title-desc') {
          var titleA = (a.dataset.title || '').toLowerCase();
          var titleB = (b.dataset.title || '').toLowerCase();
          if (titleA < titleB) return sortValue === 'title-asc' ? -1 : 1;
          if (titleA > titleB) return sortValue === 'title-asc' ? 1 : -1;
          return 0;
        }
        return 0;
      });

      // Re-append in sorted order
      articles.forEach(function (el) {
        wrapper.appendChild(el);
      });
    });
  })();
</script>