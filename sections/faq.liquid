<!-- Hero Section -->
<section class="tw-bg-no-repeat tw-relative tw-z-0 before:tw--z-10 before:tw-absolute before:tw-left-0 before:tw-top-0 before:tw-size-full before:tw-bg-menuOverlay tw-bg-cover before:tw-mix-blend-multiply" style="background-image: url({{ 'faq-hero-bg.png' | asset_url }});">
  <div class="wrapper">
    <div class="tw-h-[370px] tw-text-center tw-flex tw-justify-center tw-items-center tw-flex-col tw-gap-4">
      <h2 class="tw-text-mainGold tw-text-xl md:tw-text-3xl lg:tw-text-4xl tw-font-script">
        {{ section.settings.subheading }}
      </h2>
      <h1 class="tw-text-white tw-text-4xl md:tw-text-[45px] tw-uppercase tw-tracking-[0.338px] tw-font-osc">
        {{ section.settings.heading }}
      </h1>
    </div>
  </div>
</section>
<!-- Questions Section -->
<section class="tw-bg-backgroundDark tw-pt-10 tw-pb-12 md:tw-pb-20 lg:tw-pb-28">
  <div class="tw-z-0 tw-relative wrapper">
    <img
      src="{{ 'shape.png' | asset_url }}"
      alt="shape"
      class="tw-absolute tw-right-20 lg:tw-block tw-hidden tw--z-10">
    <img
      src="{{ 'choc-vanilla-group.png' | asset_url }}"
      alt="choc vanilla"
      class="tw-absolute tw-left-0 tw-top-20 lg:tw-block tw-hidden tw--z-10">
    <img
      src="{{ 'shape-2.png' | asset_url }}"
      alt="shape"
      class="tw-absolute tw-left-0 tw-bottom-0 lg:tw-block tw-hidden tw--z-10">
    <img
      src="{{ 'almond-1.png' | asset_url }}"
      alt="almond"
      class="tw-absolute tw-left-0 tw-top-1/2 tw-w-16 lg:tw-block tw-hidden tw--z-10">
    <img
      src="{{ 'choc-vanilla.png' | asset_url }}"
      alt="choc vanilla"
      class="tw-absolute tw-right-0 tw-bottom-0 tw-w-24 lg:tw-block tw-hidden tw--z-10">
    <img
      src="{{ 'almond.png' | asset_url }}"
      alt="almond"
      class="tw-absolute tw-right-0 tw-top-1/2 lg:tw-block tw-hidden tw--z-10">
    <img
      src="{{ 'choc-2.png' | asset_url }}"
      alt="choc"
      class="tw-absolute tw--right-10 tw-top-1/4 lg:tw-block tw-hidden tw--z-10">
    <!-- Tabs -->
    <div class="tw-flex tw-items-center tw-justify-center tw-mb-10 tw-gap-16">
      {% for category in shop.metaobjects.faq_category.values %}
        <button
          type="button"
          data-cat="{{ category.category_title }}"
          class="tw-tab tw-text-mainBlack2 tw-text-base tw-font-bold tw-capitalize tw-font-osc animate hover:tw-border-mainGold tw-border-mainGold">
          {{ category.category_title }}
        </button>
      {% endfor %}
    </div>
    {% for category in shop.metaobjects.faq_category.values %}
      <!-- Questions -->
      <div class="tw-faq-category tw-max-w-5xl tw-mx-auto" data-cat="{{ category.category_title }}">
        <h2 class="tw-text-mainBlack tw-text-2xl tw-uppercase tw-font-osc tw-font-extrabold md:tw-text-left tw-text-center">
          {{ category.category_title }} Questions
        </h2>
        <!-- Questions Container -->
        <div class="tw-space-y-2.5 md:tw-space-y-5 tw-mt-10 lg:tw-mt-5">
          {% for faqs in shop.metaobjects.faq.values %}
            {% if faqs.category.value == category %}
              <!-- Item -->
              <div class="tw-bg-white tw-py-6 tw-px-9">
                <h4 class="tw-text-mainBlack tw-text-base tw-font-bold tw-mb-2.5">{{ faqs.question.value }}</h4>
                <p class="tw-text-mainBlack tw-text-base">{{ faqs.answer_text | metafield_text }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('.tw-tab');
    const categories = document.querySelectorAll('.tw-faq-category');

    function activateTab(tab) {
      tabs.forEach(t => t.classList.remove('tw-border-b-2'));
      tab.classList.add('tw-border-b-2');
    }

    function showCategory(cat) {
      categories.forEach(category => {
        if (category.dataset.cat === cat) {
          category.style.display = 'block';
          category.style.opacity = 1;
        } else {
          category.style.display = 'none';
          category.style.opacity = 0;
        }
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const cat = this.dataset.cat;
        activateTab(this);

        categories.forEach(category => {
          if (category.style.display === 'block') {
            category.style.opacity = 0;
            setTimeout(() => {
              showCategory(cat);
            }, 300); // Duration of the fade out animation
          }
        });
      });
    });

    // Initial setup: activate the first tab and show the first category
    if (tabs.length > 0 && categories.length > 0) {
      activateTab(tabs[0]);
      showCategory(tabs[0].dataset.cat);
    }
  });
</script>

<style>
  .tw-faq-category {
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
</style>


{% schema %}
  {
    "name": "FAQ",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      }, {
        "type": "text",
        "id": "subheading",
        "label": "Sub Heading"
      }
    ]
  }
{% endschema %}