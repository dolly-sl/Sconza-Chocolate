{% assign section_data = article.metafields.custom.article_section %}

{% if section_data != blank %}
  <div class="article-custom-section">
    {{ section_data }}
  </div>
{% endif %}

<style>
  .article-custom-section {
    background: #F5F3EF;
    border-left: 4px solid #1A1B1B;
    border-radius: 4px;
    padding: 24px 28px;
    margin: 30px 0;
  }
  .article-custom-section h2,
  .article-custom-section h3 {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }
  .article-custom-section ul,
  .article-custom-section ol {
    padding-left: 20px;
    margin-top: 12px;
  }
  .article-custom-section li {
    line-height: 26px;
    color: #1A1B1B;
    margin-bottom: 6px;
  }
</style>
