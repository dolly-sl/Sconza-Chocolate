{% assign section_data = article.metafields.custom.custom_section_data %}

{% if section_data != blank %}
  <div class="article-custom-section">
    {{section_data | metafield_tag}}
  </div>
{% endif %}

<style>
  .article-custom-section {
    background: #FFFCF3;
    padding: 40px 87px 40px 63px;
    margin: 30px 0;
  }
  .article-custom-section h2,
  .article-custom-section h3 {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }
  .article-custom-section ul,
  .article-custom-section ol {
    padding-left: 20px;
    margin-top: 12px;
  }
  .article-custom-section li {
    line-height: 26px;
    color: #1A1B1B;
    margin-bottom: 6px;
  }
  .article__single .article__content h2, .article__single .article__content h3, .article__single .article__content h4, .article__single .article__content h5, .article__single .article__content h6 {
    margin-bottom: 0;
  }
</style>
