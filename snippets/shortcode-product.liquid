{% comment %}
==============================================================
  FILE: snippets/shortcode-product.liquid
  USAGE in article body (HTML source view):
    [product handle="your-product-handle"]
  
  EXAMPLE:
    [product handle="strawberry-dipped-almonds-22oz"]
==============================================================
{% endcomment %}

{% comment %} ── Resolve the product handle ── {% endcomment %}
{% comment %} sc_handle is passed directly from article.liquid via: render 'shortcode-product', sc_handle: sc_handle {% endcomment %}
{% unless sc_handle and sc_handle != blank %}
  {% comment %} Fallback: support old 'handle' param if used elsewhere {% endcomment %}
  {% assign sc_handle = handle | strip %}
{% endunless %}

{% assign sc_product = all_products[sc_handle] %}


{% if sc_product and sc_product.available %}
  <div class="sc-product-card">
    <div class="sc-product-card__image-wrap">
      {% if sc_product.featured_image %}
        <a href="{{ sc_product.url }}" class="sc-product-card__img-link">
          <img
            src="{{ sc_product.featured_image | image_url: width: 300 }}"
            alt="{{ sc_product.featured_image.alt | escape }}"
            class="sc-product-card__img"
            loading="lazy"
            width="300"
          >
        </a>
      {% endif %}
    </div>

    <div class="sc-product-card__body">

      {% comment %} Title {% endcomment %}
      <a href="{{ sc_product.url }}" class="sc-product-card__title">
        {{ sc_product.title }}
      </a>

      {% comment %} Price {% endcomment %}
      <div class="sc-product-card__price">
        {% if sc_product.price_varies %}
          <span class="sc-product-card__price-from">From</span>
        {% endif %}
        {% if sc_product.compare_at_price > sc_product.price %}
          <span class="sc-product-card__price-compare">
            {{ sc_product.compare_at_price | money }}
          </span>
        {% endif %}
        <span class="sc-product-card__price-current">
          {{ sc_product.price_min | money }}
          {% if sc_product.price_varies %} – {{ sc_product.price_max | money }}{% endif %}
        </span>
      </div>

      {% comment %} Star Rating via Shopify metafield (standard) {% endcomment %}
      {% assign rating_value = sc_product.metafields.reviews.rating.value %}
      {% assign rating_count = sc_product.metafields.reviews.rating_count.value %}
      {% if rating_value %}
        <div class="sc-product-card__stars" aria-label="Rating: {{ rating_value }} out of 5">
          {% assign full_stars  = rating_value | floor %}
          {% assign half_star   = rating_value | minus: full_stars %}
          {% assign empty_stars = 5 | minus: full_stars | minus: 1 %}

          {% for i in (1..full_stars) %}
            <svg class="sc-star sc-star--full" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78z"/></svg>
          {% endfor %}

          {% if half_star >= 0.5 %}
            <svg class="sc-star sc-star--half" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="half"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="transparent"/></linearGradient></defs><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78z" fill="url(#half)" stroke="currentColor" stroke-width="1"/></svg>
            {% assign empty_stars = empty_stars | minus: 0 %}
          {% else %}
            {% assign empty_stars = empty_stars | plus: 1 %}
          {% endif %}

          {% if empty_stars > 0 %}
            {% for i in (1..empty_stars) %}
              <svg class="sc-star sc-star--empty" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            {% endfor %}
          {% endif %}

          {% if rating_count %}
            <span class="sc-product-card__review-count">{{ rating_count }} Reviews</span>
          {% endif %}
        </div>
      {% endif %}

      {% comment %} Description (first 160 chars of product description) {% endcomment %}
      {% if sc_product.description != blank %}
        <p class="sc-product-card__desc">
          {{ sc_product.description | strip_html | truncate: 160 }}
        </p>
      {% endif %}
    </div>

    {% comment %} CTA Button {% endcomment %}
      <a href="{{ sc_product.url }}" class="sc-product-card__btn">
        Shop Now
      </a>
  </div>

{% else %}
  {% comment %} Fallback: product not found — silent in production {% endcomment %}
  {% if sc_handle != blank %}
    <!-- sc-product: "{{ sc_handle }}" not found -->
  {% endif %}
{% endif %}


<style>
  /* ── Product Card ─────────────────────────────────────── */
  .sc-product-card {
    display: flex;
    padding: 40px 75px;
    margin: 50px 0 0 0;
    background: #FFFCF3;
  }

  /* Image */
  .sc-product-card__image-wrap {
    flex-shrink: 0;
    width: 120px;
  }
  .sc-product-card__img-link { display: block; }
  .sc-product-card__img {
    width: 120px;
    height: 120px;
    object-fit: contain;
    display: block;
  }

  /* Body */
  .sc-product-card__body {
    flex: 1;
    min-width: 0;
  }

  /* Title */
  .sc-product-card__title {
    display: block;
    font-size: 18px;
    font-weight: 700;
    color: #1E1C1C;
    text-decoration: none;
    text-transform: capitalize;
    letter-spacing: 0.3px;
    margin-bottom: 2px;
    line-height: 1.3;
  }
  .sc-product-card__title:hover { text-decoration: underline; }

  /* Price */
  .sc-product-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    color: #1E1C1C;
    font-size: 16px;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
  }
  .sc-product-card__price-current {
    font-size: 14px;
    font-weight: 600;
    color: #1E1C1C;
  }
  .sc-product-card__price-compare {
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
  }
  .sc-product-card__price-from {
    font-size: 12px;
    color: #6B6B6B;
  }

  /* Stars */
  .sc-product-card__stars {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-bottom: 8px;
  }
  .sc-star {
    width: 14px;
    height: 14px;
    color: #DF9832;
  }
  .sc-star--full  { fill: currentColor; }
  .sc-star--half  { fill: none; }
  .sc-star--empty { fill: none; stroke: currentColor; stroke-width: 1.5; }
  .sc-product-card__review-count {
    font-size: 12px;
    color: #6B6B6B;
    margin-left: 4px;
  }

  /* Description */
  .sc-product-card__desc {
    font-size: 13px;
    line-height: 20px !important;
    color: #4A4A4A;
    margin-bottom: 12px;
    padding-top: 0 !important;
  }

  /* Button */
  .sc-product-card__btn {
    display: inline-block;
    padding: 9px 22px;
    background: #1E1C1C;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .sc-product-card__btn:hover { background: #DF9832; color: #fff; }
  .sc-product-card__image-wrap img {
    height: 187px;
    margin: 0;
  }
  .sc-product-card__body {
    margin: 0 50px 0 90px;
  }

  /* ── Mobile ───────────────────────────────────────────── */
  @media (max-width: 600px) {
    .sc-product-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .sc-product-card__image-wrap { width: 100%; text-align: center; }
    .sc-product-card__img { margin: 0 auto; width: 160px; height: 160px; }
    .sc-product-card__price,
    .sc-product-card__stars { justify-content: center; }
  }
</style>
