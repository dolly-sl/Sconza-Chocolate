{% comment %} ── Get the product handle from shortcode variable ── {% endcomment %}
{% comment %}
  ==============================================================
    FILE: snippets/shortcode-product.liquid
    USAGE:
    [product handle="your-product-handle"]
  ==============================================================
{% endcomment %}

{% assign sc_handle = sc_handle | strip %}
{% assign sc_product = all_products[sc_handle] %}

{% if sc_product %}
  <div class="sc-product-card">
    {% if sc_product.featured_image %}
      <div class="sc-product-card__image-wrap">
        <a href="{{ sc_product.url }}">
          <img
            src="{{ sc_product.featured_image | image_url: width: 300 }}"
            alt="{{ sc_product.title }}"
            loading="lazy"
            width="300"
          >
        </a>
      </div>
    {% endif %}

    <div class="sc-product-card__body">
      <a href="{{ sc_product.url }}" class="sc-product-card__title">
        {{ sc_product.title }}
      </a>

      <div class="sc-product-card__price">
        {% if sc_product.compare_at_price > sc_product.price %}
          <span class="sc-product-card__price-compare">
            {{ sc_product.compare_at_price | money }}
          </span>
        {% endif %}

        <span class="sc-product-card__price-current">
          {{ sc_product.price | money }}
        </span>
      </div>

      {% assign rating_value = sc_product.metafields.reviews.rating.value %}
      {% assign rating_count = sc_product.metafields.reviews.rating_count.value %}

      {% if rating_value %}
        <div class="sc-product-card__stars">
          {% assign full_stars = rating_value | floor %}

          {% for i in (1..full_stars) %}
            ★
          {% endfor %}

          <span> {{ rating_value }}/5 </span>

          {% if rating_count %}
            <span> ({{ rating_count }} Reviews) </span>
          {% endif %}
        </div>
      {% endif %}

      {% if sc_product.description != blank %}
        <p class="sc-product-card__desc">
          {{ sc_product.description | strip_html | truncate: 160 }}
        </p>
      {% endif %}

      <a href="{{ sc_product.url }}" class="sc-product-card__btn"> Shop Now </a>
    </div>
  </div>

{% else %}
  <p>Product not found: {{ sc_handle }}</p>
{% endif %}

<style>
  /* ── Product Card ─────────────────────────────────────── */
  .sc-product-card {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    border: 1px solid rgba(167, 158, 137, 0.4);
    border-radius: 4px;
    padding: 20px 24px;
    margin: 30px 0;
    background: #fffcf4;
  }

  /* Image */
  .sc-product-card__image-wrap {
    flex-shrink: 0;
    width: 120px;
  }
  .sc-product-card__img-link {
    display: block;
  }
  .sc-product-card__img {
    width: 120px;
    height: 120px;
    object-fit: contain;
    display: block;
  }

  /* Body */
  .sc-product-card__body {
    flex: 1;
    min-width: 0;
  }

  /* Title */
  .sc-product-card__title {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: #1e1c1c;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .sc-product-card__title:hover {
    text-decoration: underline;
  }

  /* Price */
  .sc-product-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }
  .sc-product-card__price-current {
    font-size: 14px;
    font-weight: 600;
    color: #1e1c1c;
  }
  .sc-product-card__price-compare {
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
  }
  .sc-product-card__price-from {
    font-size: 12px;
    color: #6b6b6b;
  }

  /* Stars */
  .sc-product-card__stars {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-bottom: 8px;
  }
  .sc-star {
    width: 14px;
    height: 14px;
    color: #df9832;
  }
  .sc-star--full {
    fill: currentColor;
  }
  .sc-star--half {
    fill: none;
  }
  .sc-star--empty {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }
  .sc-product-card__review-count {
    font-size: 12px;
    color: #6b6b6b;
    margin-left: 4px;
  }

  /* Description */
  .sc-product-card__desc {
    font-size: 13px;
    line-height: 20px !important;
    color: #4a4a4a;
    margin-bottom: 12px;
    padding-top: 0 !important;
  }

  /* Button */
  .sc-product-card__btn {
    display: inline-block;
    padding: 9px 22px;
    background: #1e1c1c;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .sc-product-card__btn:hover {
    background: #df9832;
    color: #fff;
  }

  /* ── Mobile ───────────────────────────────────────────── */
  @media (max-width: 600px) {
    .sc-product-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .sc-product-card__image-wrap {
      width: 100%;
      text-align: center;
    }
    .sc-product-card__img {
      margin: 0 auto;
      width: 160px;
      height: 160px;
    }
    .sc-product-card__price,
    .sc-product-card__stars {
      justify-content: center;
    }
  }
</style>
