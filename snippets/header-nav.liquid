{% comment %}
  <nav class="tw-hidden lg:tw-block lg:tw-gap-x-12">
  <ul class="tw-flex tw-gap-x-12">
  {% for link in linklists[nav].links %}
  <li class="{% if link.links != blank %}has-children {% endif %} {% if link.title == "Shop" %}shopMenu{% endif %}">
  <a href="{{ link.url }}" class="tw-text-nero tw-text-base tw-font-bold tw-font-os">
  {{ link.title }}
  </a>

  {% if link.links != blank %}
  <ul class="child-menu tw-hidden">
  {% for child_link in link.links %}
  <li>
  <a href="{{ child_link.url }}">
  {{ child_link.title }}
  </a>

  {% if link.title == 'Shop' %}
  {% if child_link.links != blank %}
  <ul class="grandchild-menu">
  {% for grandchild_link in child_link.links %}
  <li>
  <a href="{{ grandchild_link.url }}">
  {{ grandchild_link.title }}
  </a>
  </li>
  {% endfor %}
  </ul>
  {% endif %}
  {% endif %}
  </li>
  {% endfor %}

  {% if link.title == 'Shop' %}
  {%- for block in blocks -%}
  {%- case block.type -%}
  {%- when 'mega_menu_cta' -%}
  {{ block.settings.heading }}

  {{ block.settings.link_text }}

  {{ block.settings.link_url }}

  {%- assign image = block.settings.image -%}
  {{
  image
  | image_url: width: image.width
  | image_tag: class: 'add_your_class_here', loading: 'lazy'
  }}
  {%- endcase -%}
  {%- endfor -%}
  {% endif %}
  </ul>
  {% endif %}
  </li>
  {% endfor %}
  </ul>
  </nav>
{% endcomment %}

<nav class="tw-hidden lg:tw-w-1/3 lg:tw-block">
  <ul class="tw-flex tw-items-center tw-list-none tw-gap-7">
    {% for link in linklists[nav].links %}
      <li
        {% if link.links != blank %}
        class="dropdown-toggle"
        {% endif %}>
        <a
          href="{{ link.url }}"
          class="tw-text-base tw-font-bold tw-text-mainBlack animate"
          {% if link.links != blank %}
          onclick="return false;"
          {% endif %}>
          {{ link.title }}
        </a>

        {% if link.links != blank and link.title == 'Shop' %}
          <!-- Mega Menu Desktop -->
          <div class="tw-absolute tw-left-0 tw-z-10 tw-hidden tw-w-full tw-bg-white tw-pt-7 tw-pb-12 tw-top-full dropdown">
            <div class="wrapper">
              <div class="tw-flex tw-items-start tw-justify-between lg:tw-gap-10 xl:tw-gap-28">
                <div class="tw-flex tw-items-start tw-justify-between tw-flex-1 tw-gap-9">
                  <!-- Column 1 -->
                  <div>
                    {% for child_link in link.links limit: 1 %}
                      <div
                        {% if forloop.first != true %}
                        class="tw-mt-10"
                        {% endif %}>
                        <p class="tw-font-bold tw-mb-[18px] tw-text-mainBlack">{{ child_link.title }}</p>
                        {% if child_link.links != blank %}
                          <ul class="tw-flex tw-flex-col tw-gap-5 tw-list-none">
                            {% for grandchild_link in child_link.links %}
                              <li>
                                <a href="{{ grandchild_link.url }}" class="tw-text-base tw-capitalize animate">
                                  {{ grandchild_link.title }}
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                  <!-- Column 2 -->
                  <div>
                    {% for child_link in link.links limit: 1 offset: 1 %}
                      <div
                        {% if forloop.first != true %}
                        class="tw-mt-10"
                        {% endif %}>
                        <p class="tw-font-bold tw-mb-[18px] tw-text-mainBlack">{{ child_link.title }}</p>
                        {% if child_link.links != blank %}
                          <ul class="tw-flex tw-flex-col tw-gap-5 tw-list-none">
                            {% for grandchild_link in child_link.links %}
                              <li>
                                <a href="{{ grandchild_link.url }}" class="tw-text-base tw-capitalize animate">
                                  {{ grandchild_link.title }}
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                  <!-- Column 3 -->
                  <div>
                    {% for child_link in link.links limit: 1 offset: 2 %}
                      <div
                        {% if forloop.first != true %}
                        class="tw-mt-10"
                        {% endif %}>
                        <p class="tw-font-bold tw-mb-[18px] tw-text-mainBlack">{{ child_link.title }}</p>
                        {% if child_link.links != blank %}
                          <ul class="tw-flex tw-flex-col tw-gap-5 tw-list-none">
                            {% for grandchild_link in child_link.links %}
                              <li>
                                <a href="{{ grandchild_link.url }}" class="tw-text-base tw-capitalize animate">
                                  {{ grandchild_link.title }}
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                </div>
                <div class="lg:tw-w-[450px] xl:tw-w-[500px] tw-space-y-7">
                  {%- for block in blocks -%}
                    {%- case block.type -%}
                      {%- when 'mega_menu_cta' -%}
                        <!-- Item -->
                        {%- assign image = block.settings.image -%}
                        <div class="tw-flex tw-items-center tw-justify-start !tw-bg-cover !tw-bg-no-repeat tw-h-[175px] tw-px-9" style="background: url({{ image | image_url: width: image.width }});">
                          <div>
                            <p class="tw-font-bold tw-capitalize tw-mb-0.5">{{ block.settings.heading }}</p>
                            <a href="{{ block.settings.link_url }}" class="tw-text-xs tw-font-bold animate tw-capitalize tw-border-b tw-text-mainBlack tw-border-mainGold">
                              {{ block.settings.link_text }}
                            </a>
                          </div>
                        </div>
                    {%- endcase -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>